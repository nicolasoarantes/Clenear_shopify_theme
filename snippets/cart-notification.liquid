<cart-notification><div class="cart-notification-wrapper{% if desktop_menu_type != 'drawer' %} page-width{% endif %}"><div id="cart-notification" class="cart-notification focus-inset{% if color_scheme %} color-{{ color_scheme }} gradient{% endif %}" aria-modal="true" role="dialog" tabindex="-1"><div class="cart-notification__header"><h2 class="cart-notification__heading caption-large">{{ 'general.cart.item_added' | t }}</h2><button type="button" class="cart-notification__close link"><span class="svg-wrapper">{{- 'icon-close.svg' | inline_asset_content -}}</span></button></div><div id="cart-notification-product"></div><div class="cart-notification__links"><button type="button" class="link">{{ 'general.continue_shopping' | t }}</button></div></div></div></cart-notification>