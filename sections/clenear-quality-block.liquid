<section class="cl-section cl-quality" id="pesquisa-qualidade"><div class="cl-wrap">
  <div class="cl-section-head">{%- if section.settings.eyebrow != blank -%}<p class="cl-label" style="justify-content:center;">{{ section.settings.eyebrow | escape }}</p>{%- endif -%}<h2 class="cl-h2">{{ section.settings.heading }}</h2>{%- if section.settings.subtext != blank -%}<p class="cl-lead">{{ section.settings.subtext }}</p>{%- endif -%}</div>
  <div class="cl-quality__grid">{%- for block in section.blocks -%}{%- if block.type == 'pillar' -%}<div class="cl-quality__card cl-fade-in" {{ block.shopify_attributes }}><div class="cl-quality__card-img" style="background:linear-gradient(135deg,var(--cl-green-soft),var(--cl-green-tint));display:flex;align-items:center;justify-content:center;font-size:4.8rem;">{%- if block.settings.image != blank -%}{{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', sizes: '30vw', alt: block.settings.title | default: 'Qualidade' }}{%- else -%}{{ block.settings.emoji | default: '🧪' }}{%- endif -%}</div><div class="cl-quality__card-body"><div class="cl-quality__card-num">{{ block.settings.number | escape }}</div><h3 class="cl-quality__card-title">{{ block.settings.title | escape }}</h3><p class="cl-quality__card-text">{{ block.settings.text | escape }}</p></div></div>{%- endif -%}{%- endfor -%}</div>
</div></section>
{% schema %}{"name":"Clenear: Qualidade","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Pesquisa e qualidade"},{"type":"text","id":"heading","label":"Título","default":"Desenvolvimento que se comprova"},{"type":"textarea","id":"subtext","label":"Subtexto","default":"Cada produto Clenear é desenvolvido com atenção à performance e consistência."}],"blocks":[{"type":"pillar","name":"Pilar","settings":[{"type":"image_picker","id":"image","label":"Imagem"},{"type":"text","id":"emoji","label":"Emoji","default":"🧪"},{"type":"text","id":"number","label":"Número","default":"01"},{"type":"text","id":"title","label":"Título"},{"type":"textarea","id":"text","label":"Texto"}]}],"presets":[{"name":"Clenear Qualidade","blocks":[{"type":"pillar","settings":{"emoji":"⚗️","number":"01","title":"Desenvolvimento de fórmulas","text":"Formulado internamente com foco em eficiência, segurança e rendimento."}},{"type":"pillar","settings":{"emoji":"🔬","number":"02","title":"Controle de qualidade","text":"Processos em todas as etapas garantem padrão constante."}},{"type":"pillar","settings":{"emoji":"✅","number":"03","title":"Resultado comprovado","text":"Testado em aplicações reais: limpeza pesada, automotivo, lavanderia."}}]}]}{% endschema %}