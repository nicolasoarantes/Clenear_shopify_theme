<div class="cl-strip"><div class="cl-wrap"><div class="cl-strip__items">{%- for block in section.blocks -%}{%- if block.type == 'item' -%}<div class="cl-strip__item" {{ block.shopify_attributes }}><div class="cl-strip__icon" aria-hidden="true">{{ block.settings.emoji }}</div><span>{{ block.settings.label | escape }}</span></div>{%- unless forloop.last -%}<div class="cl-strip__divider" aria-hidden="true"></div>{%- endunless -%}{%- endif -%}{%- endfor -%}</div></div></div>
{% schema %}{"name":"Clenear: Strip","blocks":[{"type":"item","name":"Item","settings":[{"type":"text","id":"emoji","label":"Emoji","default":"✓"},{"type":"text","id":"label","label":"Texto"}]}],"presets":[{"name":"Clenear Strip","blocks":[{"type":"item","settings":{"emoji":"🏭","label":"Indústria capixaba desde 2006"}},{"type":"item","settings":{"emoji":"⚗️","label":"Desenvolvimento técnico"}},{"type":"item","settings":{"emoji":"📦","label":"Linhas completas"}},{"type":"item","settings":{"emoji":"🎯","label":"Atendimento consultivo"}},{"type":"item","settings":{"emoji":"🌿","label":"Compromisso ambiental"}}]}]}{% endschema %}