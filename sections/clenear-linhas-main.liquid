{{ 'clenear-pages.css' | asset_url | stylesheet_tag }}

<div class="cl-pg-page" id="nossas-linhas">

  {%- comment -%} ===== HERO INSTITUCIONAL ===== {%- endcomment -%}
  <section class="cl-pg-hero" style="min-height:56vh;display:flex;align-items:center;">
    <div class="cl-pg-wrap" style="width:100%;">
      <div style="max-width:80rem;margin:0 auto;text-align:center;" class="cl-pg-fade">
        <p class="cl-pg-eyebrow">{{ section.settings.hero_eyebrow | default: 'Nossas linhas' }}</p>
        <h1 class="cl-pg-h1" style="margin-bottom:2rem;">{{ section.settings.hero_title | default: 'Soluções desenvolvidas para <em>cada segmento</em>' }}</h1>
        <p class="cl-pg-lead" style="margin-left:auto;margin-right:auto;max-width:65rem;">{{ section.settings.hero_subtitle | default: 'Cada linha Clenear é formulada com rigor técnico para entregar desempenho real no dia a dia de empresas, lavanderias, revendedores e profissionais automotivos.' }}</p>
        <div class="cl-pg-btn-row" style="justify-content:center;">
          <a href="{{ section.settings.cta_wa_url | default: 'https://api.whatsapp.com/send?phone=552732280140&text=Ol%C3%A1!%20Vim%20pelo%20site%20da%20Clenear%20e%20gostaria%20de%20saber%20mais%20sobre%20as%20linhas%20de%20produto.' }}" class="cl-pg-btn cl-pg-btn--wa" target="_blank" rel="noopener">
            {{ section.settings.cta_wa_label | default: 'Falar sobre as linhas' }}
          </a>
          <a href="{{ section.settings.cta2_url | default: '/pages/contato' }}" class="cl-pg-btn cl-pg-btn--outline">
            {{ section.settings.cta2_label | default: 'Formulário de contato' }}
          </a>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ===== GRID DE LINHAS ===== {%- endcomment -%}
  <section class="cl-pg-section cl-pg-section--alt">
    <div class="cl-pg-wrap">
      <div class="cl-pg-intro cl-pg-intro--center cl-pg-fade">
        <p class="cl-pg-eyebrow">{{ section.settings.grid_eyebrow | default: 'Portfólio institucional' }}</p>
        <h2 class="cl-pg-h2">{{ section.settings.grid_title | default: 'Linhas completas para cada necessidade' }}</h2>
        <p class="cl-pg-lead cl-pg-lead--wide">{{ section.settings.grid_subtitle | default: 'Produtos com qualidade, performance e suporte técnico para cada segmento do mercado profissional.' }}</p>
      </div>

      <div class="cl-pg-cards cl-pg-cards--linhas cl-pg-fade">
        {%- for block in section.blocks -%}
          {%- if block.type == 'linha' -%}
            {%- assign wa_text = 'Olá! Vim pelo site da Clenear e gostaria de saber mais sobre a linha ' | append: block.settings.title | url_encode -%}
            <div class="cl-pg-card cl-pg-card--linha" {{ block.shopify_attributes }}>
              <div class="cl-pg-card__img">
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', widths: '300, 500, 600', sizes: '(min-width: 768px) 30vw, 85vw', alt: block.settings.title }}
                {%- else -%}
                  <div class="cl-pg-placeholder" style="min-height:18rem;">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                    <span>Imagem da linha<br>(aspect 4:3)</span>
                  </div>
                {%- endif -%}
              </div>
              <span class="cl-pg-card__tag">{{ block.settings.tag | default: 'Linha profissional' }}</span>
              <h3 class="cl-pg-card__title">{{ block.settings.title }}</h3>
              <p class="cl-pg-card__text">{{ block.settings.description }}</p>
              <a href="https://api.whatsapp.com/send?phone=552732280140&text={{ wa_text }}" class="cl-pg-card__link" target="_blank" rel="noopener" aria-label="Saiba mais sobre {{ block.settings.title }} via WhatsApp">
                Saiba mais via WhatsApp <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
      <div class="cl-pg-scroll-dots" aria-hidden="true">
        <span></span><span></span><span></span><span></span>
      </div>
    </div>
  </section>

  {%- comment -%} ===== DIFERENCIAIS DA LINHA ===== {%- endcomment -%}
  <section class="cl-pg-section cl-pg-section--dark">
    <div class="cl-pg-wrap">
      <div class="cl-pg-split">
        <div class="cl-pg-fade">
          <p class="cl-pg-eyebrow">{{ section.settings.why_eyebrow | default: 'Por que escolher a Clenear' }}</p>
          <h2 class="cl-pg-h2">{{ section.settings.why_title | default: 'Qualidade <em>comprovada</em> em cada linha' }}</h2>
          <p class="cl-pg-lead">{{ section.settings.why_text | default: 'Todas as linhas Clenear passam por desenvolvimento técnico interno, controle rigoroso de qualidade e validação em aplicações reais.' }}</p>
          <ul class="cl-pg-split__list">
            <li>Formulação própria com insumos selecionados</li>
            <li>Alto rendimento por diluição controlada</li>
            <li>Suporte técnico especializado incluído</li>
            <li>Compatíveis com uso profissional intensivo</li>
            <li>Produção local no Espírito Santo</li>
          </ul>
          <div class="cl-pg-btn-row">
            <a href="{{ section.settings.cta_wa_url | default: 'https://api.whatsapp.com/send?phone=552732280140&text=Ol%C3%A1!%20Vim%20pelo%20site%20da%20Clenear%20e%20gostaria%20de%20um%20or%C3%A7amento.' }}" class="cl-pg-btn cl-pg-btn--wa" target="_blank" rel="noopener">
              Pedir orçamento
            </a>
          </div>
        </div>
        <div class="cl-pg-split__media cl-pg-fade cl-pg-fade--d2">
          {%- if section.settings.why_image != blank -%}
            {{ section.settings.why_image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '400, 700, 800', sizes: '(min-width: 1024px) 44vw, 90vw', alt: 'Qualidade Clenear' }}
          {%- else -%}
            <div class="cl-pg-placeholder">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
              <span>Foto laboratório ou produção<br>(16:9)</span>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ===== MID CTA ===== {%- endcomment -%}
  <section class="cl-pg-section--sm cl-pg-section--alt">
    <div class="cl-pg-wrap">
      <div class="cl-pg-mid-cta cl-pg-fade">
        <h3>{{ section.settings.mid_cta_heading | default: 'Qual linha é ideal para o seu negócio?' }}</h3>
        <p>{{ section.settings.mid_cta_text | default: 'Nossa equipe técnica orienta você na escolha dos produtos certos para cada aplicação.' }}</p>
        <div class="cl-pg-btn-row">
          <a href="{{ section.settings.cta_wa_url | default: 'https://api.whatsapp.com/send?phone=552732280140&text=Ol%C3%A1!%20Vim%20pelo%20site%20da%20Clenear%20e%20gostaria%20de%20or%C3%A7amento%20ou%20indica%C3%A7%C3%A3o%20de%20linha.' }}" class="cl-pg-btn cl-pg-btn--wa" target="_blank" rel="noopener">
            {{ section.settings.cta_wa_label | default: 'Falar com especialista' }}
          </a>
          <a href="{{ section.settings.cta2_url | default: '/pages/contato' }}" class="cl-pg-btn cl-pg-btn--outline">
            {{ section.settings.cta2_label | default: 'Formulário de contato' }}
          </a>
        </div>
      </div>
    </div>
  </section>

</div>

<style>
  .cl-pg-cards--linhas {
    grid-template-columns: repeat(3, 1fr);
  }
  @media (max-width: 1023px) {
    .cl-pg-cards--linhas {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<script>
(function () {
  var fades = document.querySelectorAll('#nossas-linhas .cl-pg-fade');
  if ('IntersectionObserver' in window) {
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
      });
    }, { threshold: 0.1 });
    fades.forEach(function (el) { io.observe(el); });
  } else {
    fades.forEach(function (el) { el.classList.add('is-visible'); });
  }
})();
</script>

{% schema %}
{
  "name": "Clenear: Nossas Linhas",
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "text", "id": "hero_eyebrow", "label": "Eyebrow", "default": "Nossas linhas" },
    { "type": "text", "id": "hero_title", "label": "Título", "default": "Soluções desenvolvidas para <em>cada segmento</em>" },
    { "type": "textarea", "id": "hero_subtitle", "label": "Subtítulo" },
    { "type": "header", "content": "CTAs globais" },
    { "type": "text", "id": "cta_wa_label", "label": "WhatsApp label", "default": "Falar sobre as linhas" },
    { "type": "url", "id": "cta_wa_url", "label": "WhatsApp link" },
    { "type": "text", "id": "cta2_label", "label": "CTA 2 label", "default": "Formulário de contato" },
    { "type": "url", "id": "cta2_url", "label": "CTA 2 link" },
    { "type": "header", "content": "Grid de linhas" },
    { "type": "text", "id": "grid_eyebrow", "label": "Eyebrow", "default": "Portfólio institucional" },
    { "type": "text", "id": "grid_title", "label": "Título" },
    { "type": "textarea", "id": "grid_subtitle", "label": "Subtítulo" },
    { "type": "header", "content": "Seção: Por que a Clenear" },
    { "type": "text", "id": "why_eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "why_title", "label": "Título" },
    { "type": "textarea", "id": "why_text", "label": "Texto" },
    { "type": "image_picker", "id": "why_image", "label": "Imagem (16:9)" },
    { "type": "header", "content": "Mid CTA" },
    { "type": "text", "id": "mid_cta_heading", "label": "Título" },
    { "type": "textarea", "id": "mid_cta_text", "label": "Texto" }
  ],
  "blocks": [
    {
      "type": "linha",
      "name": "Linha de produto",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Imagem (4:3)" },
        { "type": "text", "id": "tag", "label": "Tag / segmento", "default": "Linha profissional" },
        { "type": "text", "id": "title", "label": "Nome da linha" },
        { "type": "textarea", "id": "description", "label": "Descrição institucional" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Clenear: Nossas Linhas",
      "blocks": [
        { "type": "linha", "settings": { "tag": "Higiene têxtil", "title": "Lavanderia", "description": "Amaciantes, detergentes concentrados e soluções para higienização têxtil. Formulações eficazes para lavanderias comerciais e industriais com alto rendimento por diluição." } },
        { "type": "linha", "settings": { "tag": "Automotivo", "title": "Limpeza Automotiva", "description": "Linha completa Brilha+, Limpa+, Descola+ e Revita+. Produtos com performance comprovada para estéticas, revenda e uso profissional em veículos." } },
        { "type": "linha", "settings": { "tag": "Corporativo", "title": "Uso Profissional", "description": "Soluções para limpeza e higiene em ambientes corporativos, hospitais, escolas e indústrias. Padrão constante de qualidade e rendimento para grandes volumes." } },
        { "type": "linha", "settings": { "tag": "Alta performance", "title": "Alta Concentração", "description": "Produtos com altíssimo rendimento por diluição controlada. Ideais para revendedores e empresas que buscam reduzir custo operacional sem abrir mão de eficiência." } },
        { "type": "linha", "settings": { "tag": "Industrial", "title": "Aditivos Industriais", "description": "Formulações técnicas para remoção de graxa pesada, óleos industriais, sujeiras agressivas e manutenção de equipamentos. Para uso em fábricas e oficinas." } },
        { "type": "linha", "settings": { "tag": "Essências & Insumos", "title": "Exóticas & Matérias-Primas", "description": "Essências, fragrâncias e matérias-primas para formuladores, marcas próprias e empresas que desenvolvem seus próprios produtos de limpeza." } }
      ]
    }
  ]
}
{% endschema %}
