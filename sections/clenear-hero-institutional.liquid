<section class="clenear-institutional-shell clenear-hero">
  <div class="clenear-container">
    <div class="clenear-hero__grid">
      <div class="clenear-hero__content">
        {%- if section.settings.eyebrow != blank -%}<p class="clenear-eyebrow">{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
        <h1 class="clenear-heading">{{ section.settings.heading }}</h1>
        {%- if section.settings.subheading != blank -%}<p class="clenear-text">{{ section.settings.subheading }}</p>{%- endif -%}
        <div class="clenear-button-row">
          {%- if section.settings.primary_label != blank -%}<a class="clenear-button clenear-button--primary" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label | escape }}</a>{%- endif -%}
          {%- if section.settings.secondary_label != blank -%}<a class="clenear-button clenear-button--secondary" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label | escape }}</a>{%- endif -%}
        </div>
      </div>
      <div class="clenear-hero__media">
        {%- if section.settings.image != blank -%}{{ section.settings.image | image_url: width: 1000 | image_tag: loading: 'eager', widths: '360, 540, 720, 900, 1000', sizes: '(min-width: 990px) 46vw, 92vw', alt: section.settings.image_alt }}{%- else -%}<div class="clenear-visual-placeholder"><p>Clenear</p></div>{%- endif -%}
      </div>
    </div>
  </div>
</section>
{% schema %}{"name":"Clenear Hero","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow"},{"type":"inline_richtext","id":"heading","label":"Heading","default":"Soluções profissionais"},{"type":"textarea","id":"subheading","label":"Subheading"},{"type":"text","id":"primary_label","label":"Primary button"},{"type":"url","id":"primary_link","label":"Primary link"},{"type":"text","id":"secondary_label","label":"Secondary button"},{"type":"url","id":"secondary_link","label":"Secondary link"},{"type":"image_picker","id":"image","label":"Image"},{"type":"text","id":"image_alt","label":"Image alt"}],"presets":[{"name":"Clenear Hero"}]}{% endschema %}