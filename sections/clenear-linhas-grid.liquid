{{ 'clenear-pages.css' | asset_url | stylesheet_tag }}

<section class="cl-pg-section cl-pg-section--alt cl-lg" id="linhas-grid">
  <div class="cl-pg-wrap">
    <div class="cl-pg-intro cl-pg-intro--center cl-pg-fade">
      <p class="cl-pg-eyebrow">{{ section.settings.grid_eyebrow | default: 'Portfólio institucional' }}</p>
      <h2 class="cl-pg-h2">{{ section.settings.grid_title | default: 'Linhas completas para cada segmento' }}</h2>
      <p class="cl-pg-lead cl-pg-lead--wide">{{ section.settings.grid_subtitle | default: 'Produtos com qualidade, performance e suporte técnico para cada necessidade profissional.' }}</p>
    </div>
    <div class="cl-pg-cards cl-pg-cards--linhas cl-pg-fade">
      {%- for block in section.blocks -%}
        {%- if block.type == 'linha' -%}
          {%- assign wa_text = 'Olá! Vim pelo site da Clenear e gostaria de saber mais sobre a linha ' | append: block.settings.title | url_encode -%}
          <div class="cl-pg-card cl-pg-card--linha" {{ block.shopify_attributes }}>
            <div class="cl-pg-card__img">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', widths: '300, 500, 600', sizes: '(min-width: 768px) 30vw, 85vw', alt: block.settings.title }}
              {%- else -%}
                <div class="cl-pg-placeholder" style="min-height:18rem;"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg><span>Imagem da linha<br>(aspecto 4:3)</span></div>
              {%- endif -%}
            </div>
            <span class="cl-pg-card__tag">{{ block.settings.tag | default: 'Linha profissional' }}</span>
            <h3 class="cl-pg-card__title">{{ block.settings.title }}</h3>
            <p class="cl-pg-card__text">{{ block.settings.description }}</p>
            <div style="display:flex;flex-wrap:wrap;gap:10px;margin-top:auto;">
              <a href="https://api.whatsapp.com/send?phone=552732280140&text={{ wa_text }}" class="cl-pg-card__link" target="_blank" rel="noopener">Saiba mais via WhatsApp <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
              {%- if block.settings.anchor_id != blank -%}
                <a href="#linha-{{ block.settings.anchor_id }}" class="cl-pg-card__link cl-pg-card__link--outline">Ver produtos ↓</a>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
    <div class="cl-pg-scroll-dots" aria-hidden="true"><span></span><span></span><span></span><span></span></div>
  </div>
</section>
<style>
.cl-pg-cards--linhas{grid-template-columns:repeat(3,1fr)}
@media(max-width:1023px){.cl-pg-cards--linhas{grid-template-columns:repeat(2,1fr)}}
.cl-pg-card__link--outline{color:#4dd1b0;border:1px solid rgba(77,209,176,0.4);border-radius:4px;padding:6px 12px;font-size:13px;text-decoration:none;display:inline-flex;align-items:center}
.cl-pg-card__link--outline:hover{background:rgba(77,209,176,0.08);color:#4dd1b0}
</style>
<script>
(function(){
  var fades=document.querySelectorAll('#linhas-grid .cl-pg-fade');
  if('IntersectionObserver' in window){
    var io=new IntersectionObserver(function(e){e.forEach(function(x){if(x.isIntersecting){x.target.classList.add('is-visible');io.unobserve(x.target);}});},{threshold:0.1});
    fades.forEach(function(el){io.observe(el);});
  } else { fades.forEach(function(el){el.classList.add('is-visible');}); }
})();
</script>
{% schema %}
{
  "name": "Grid de Linhas",
  "settings": [
    { "type": "text",     "id": "grid_eyebrow",  "label": "Eyebrow",   "default": "Portfólio institucional" },
    { "type": "text",     "id": "grid_title",    "label": "Título",    "default": "Linhas completas para cada segmento" },
    { "type": "textarea", "id": "grid_subtitle", "label": "Subtítulo", "default": "Produtos com qualidade, performance e suporte técnico para cada necessidade profissional." }
  ],
  "blocks": [
    {
      "type": "linha",
      "name": "Linha de produto",
      "settings": [
        { "type": "image_picker", "id": "image",       "label": "Imagem (4:3)" },
        { "type": "text",         "id": "tag",         "label": "Tag / segmento", "default": "Linha profissional" },
        { "type": "text",         "id": "title",       "label": "Nome da linha" },
        { "type": "textarea",     "id": "description", "label": "Descrição institucional" },
        { "type": "text",         "id": "anchor_id",   "label": "ID âncora (ex: domissanitaria)", "info": "Liga o card à seção de sublinhas via link #linha-{id}" }
      ]
    }
  ],
  "presets": [{ "name": "Grid de Linhas" }]
}
{% endschema %}
