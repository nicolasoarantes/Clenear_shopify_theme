<section class="clenear-institutional-shell clenear-section">
  <div class="clenear-container">
    <div class="clenear-centered">
      {%- if section.settings.eyebrow != blank -%}
        <p class="clenear-eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      <h2 class="clenear-heading clenear-heading--section">{{ section.settings.heading }}</h2>
    </div>

    <div class="clenear-feature-row">
      {%- for block in section.blocks -%}
        <article class="clenear-feature" {{ block.shopify_attributes }}>
          <h3>{{ block.settings.heading }}</h3>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Clenear diferenciais",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto superior",
      "default": "Diferenciais"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Titulo",
      "default": "Estrutura tecnica para entregar consistencia"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Diferencial",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Texto",
          "default": "Desenvolvimento técnico de fórmulas"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Clenear diferenciais"
    }
  ]
}
{% endschema %}
