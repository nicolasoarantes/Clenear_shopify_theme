<section class="cl-section cl-reseller cl-dark" id="revenda"><div class="cl-reseller__deco" aria-hidden="true"></div><div class="cl-wrap"><div class="cl-reseller__inner">
  <div>{%- if section.settings.eyebrow != blank -%}<p class="cl-label">{{ section.settings.eyebrow | escape }}</p>{%- endif -%}<h2 class="cl-h2">{{ section.settings.heading }}</h2>{%- if section.settings.subtext != blank -%}<p class="cl-lead">{{ section.settings.subtext }}</p>{%- endif -%}<ul class="cl-reseller__benefits">{%- for block in section.blocks -%}{%- if block.type == 'benefit' -%}<li class="cl-reseller__benefit" {{ block.shopify_attributes }}><span class="cl-reseller__benefit-icon" aria-hidden="true">{{ block.settings.icon }}</span>{{ block.settings.text | escape }}</li>{%- endif -%}{%- endfor -%}</ul></div>
  <div class="cl-reseller__cta-box">{%- if section.settings.box_eyebrow != blank -%}<p style="color:var(--cl-mint);font-size:1.2rem;font-weight:800;letter-spacing:.12em;text-transform:uppercase;margin-bottom:1.2rem;">{{ section.settings.box_eyebrow | escape }}</p>{%- endif -%}<h3 class="cl-h2">{{ section.settings.box_heading }}</h3><p class="cl-body">{{ section.settings.box_text }}</p><div class="cl-btn-row" style="justify-content:center;">{%- if section.settings.cta_wa_label != blank -%}<a href="{{ section.settings.cta_wa_url }}" class="cl-btn cl-btn--whatsapp" target="_blank" rel="noopener">{{ section.settings.cta_wa_label | escape }}</a>{%- endif -%}{%- if section.settings.cta2_label != blank -%}<a href="{{ section.settings.cta2_url }}" class="cl-btn cl-btn--ghost">{{ section.settings.cta2_label | escape }}</a>{%- endif -%}</div>{%- if section.settings.note != blank -%}<p style="color:rgba(255,255,255,.4);font-size:1.3rem;margin-top:2rem;">{{ section.settings.note | escape }}</p>{%- endif -%}</div>
</div></div></section>
{% schema %}{"name":"Clenear: CTA Revenda","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Seja parceiro Clenear"},{"type":"text","id":"heading","label":"Título","default":"Expanda seu negócio"},{"type":"textarea","id":"subtext","label":"Subtexto","default":"Revendedores Clenear têm acesso a portfólio amplo e orientação técnica."},{"type":"text","id":"box_eyebrow","label":"Box eyebrow","default":"Fale agora"},{"type":"text","id":"box_heading","label":"Box título","default":"Quero ser revendedor"},{"type":"textarea","id":"box_text","label":"Box texto","default":"Entre em contato com nossa equipe e comece a revender."},{"type":"text","id":"cta_wa_label","label":"WhatsApp","default":"Falar com comercial"},{"type":"url","id":"cta_wa_url","label":"WhatsApp link"},{"type":"text","id":"cta2_label","label":"CTA 2","default":"Ver condições"},{"type":"url","id":"cta2_url","label":"CTA 2 link"},{"type":"text","id":"note","label":"Nota","default":"Atendimento em dias úteis."}],"blocks":[{"type":"benefit","name":"Benefício","settings":[{"type":"text","id":"icon","label":"Emoji","default":"✓"},{"type":"text","id":"text","label":"Texto"}]}],"presets":[{"name":"Clenear Revenda CTA","blocks":[{"type":"benefit","settings":{"icon":"📦","text":"Linhas completas para múltiplos segmentos"}},{"type":"benefit","settings":{"icon":"💼","text":"Condições para revendedores"}},{"type":"benefit","settings":{"icon":"🎯","text":"Orientação técnica e suporte"}},{"type":"benefit","settings":{"icon":"🚀","text":"Automotivo, lavanderia, corporativo"}},{"type":"benefit","settings":{"icon":"🤝","text":"Parceria de longo prazo"}}]}]}{% endschema %}