<section class="cl-section cl-auto cl-dark" id="linha-automotiva"><div class="cl-auto__bg" aria-hidden="true"></div>
<div class="cl-wrap"><div class="cl-auto__grid">
  <div class="cl-auto__products">{%- for block in section.blocks -%}{%- if block.type == 'product_card' -%}<div class="cl-auto__product-wrap" {{ block.shopify_attributes }}><div class="cl-auto__product-card">{%- if block.settings.image != blank -%}{{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', widths: '300, 450, 600', sizes: '22vw', alt: block.settings.name | default: 'Produto' }}{%- else -%}<div style="width:100%;height:100%;background:linear-gradient(160deg,#1A5C30,#0D3B20);display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.3);font-size:3.2rem;">🧴</div>{%- endif -%}</div>{%- if block.settings.name != blank -%}<div class="cl-auto__product-label">{{ block.settings.name | escape }}</div>{%- endif -%}</div>{%- endif -%}{%- endfor -%}</div>
  <div>{%- if section.settings.eyebrow != blank -%}<p class="cl-label">{{ section.settings.eyebrow | escape }}</p>{%- endif -%}<h2 class="cl-h2">{{ section.settings.heading }}</h2>{%- if section.settings.subtext != blank -%}<p class="cl-lead">{{ section.settings.subtext }}</p>{%- endif -%}<ul class="cl-auto__list">{%- for block in section.blocks -%}{%- if block.type == 'benefit' -%}<li {{ block.shopify_attributes }}>{{ block.settings.text | escape }}</li>{%- endif -%}{%- endfor -%}</ul><div class="cl-btn-row">{%- if section.settings.cta_label != blank -%}<a href="{{ section.settings.cta_url }}" class="cl-btn cl-btn--primary">{{ section.settings.cta_label | escape }}</a>{%- endif -%}{%- if section.settings.cta2_label != blank -%}<a href="{{ section.settings.cta2_url }}" class="cl-btn cl-btn--ghost">{{ section.settings.cta2_label | escape }}</a>{%- endif -%}</div></div>
</div></div>
<div class="cl-wave cl-wave--down"><svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none"><path d="M0 30 Q360 0 720 30 Q1080 60 1440 30 L1440 0 L0 0 Z" fill="{{ section.settings.wave_color | default: '#F7FAF8' }}"/></svg></div>
</section>
{% schema %}{"name":"Clenear: Linha Automotiva","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Linha automotiva"},{"type":"text","id":"heading","label":"Título","default":"Performance e proteção para o cuidado veicular"},{"type":"textarea","id":"subtext","label":"Subtexto","default":"A Linha+ Clenear: resultado visível, proteção duradoura e praticidade."},{"type":"text","id":"cta_label","label":"CTA 1","default":"Ver linha"},{"type":"url","id":"cta_url","label":"CTA 1 link"},{"type":"text","id":"cta2_label","label":"CTA 2","default":"Pedir orçamento"},{"type":"url","id":"cta2_url","label":"CTA 2 link"},{"type":"text","id":"wave_color","label":"Cor onda","default":"#F7FAF8"}],"blocks":[{"type":"product_card","name":"Produto","settings":[{"type":"image_picker","id":"image","label":"Imagem"},{"type":"text","id":"name","label":"Nome"}]},{"type":"benefit","name":"Benefício","settings":[{"type":"text","id":"text","label":"Texto"}]}],"presets":[{"name":"Clenear Linha Automotiva","blocks":[{"type":"product_card","settings":{"name":"Brilha+"}},{"type":"product_card","settings":{"name":"Limpa+"}},{"type":"product_card","settings":{"name":"Descola+"}},{"type":"product_card","settings":{"name":"Revita+"}},{"type":"benefit","settings":{"text":"Brilho intenso com proteção UV"}},{"type":"benefit","settings":{"text":"Limpeza profunda sem agredir pinturas"}},{"type":"benefit","settings":{"text":"Remove piche, cola e resíduos"}},{"type":"benefit","settings":{"text":"Revitaliza borrachas e pneus"}}]}]}{% endschema %}