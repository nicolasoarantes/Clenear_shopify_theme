{{ 'clenear-home-v2.css' | asset_url | stylesheet_tag }}
<div class="cl-hero cl-dark" style="padding:7.2rem 0 6.4rem;min-height:auto;"><div class="cl-hero__bg-shape cl-hero__bg-shape--1" aria-hidden="true"></div><div class="cl-wrap" style="position:relative;z-index:1;"><p class="cl-label">{{ section.settings.eyebrow | default: 'Seja um parceiro' }}</p><h1 class="cl-hero__h1" style="max-width:72rem;">{{ section.settings.heading | default: 'Revenda Clenear e expanda seu negócio' }}</h1>{%- if section.settings.subtext != blank -%}<p class="cl-hero__sub">{{ section.settings.subtext }}</p>{%- endif -%}<div class="cl-btn-row"><a href="{{ section.settings.cta_wa | default: 'https://api.whatsapp.com/send?phone=552732280140' }}" class="cl-btn cl-btn--whatsapp" target="_blank" rel="noopener">Falar com o comercial</a><a href="/pages/contact" class="cl-btn cl-btn--ghost">Enviar mensagem</a></div></div></div>
<section class="cl-section" style="background:#fff;"><div class="cl-wrap"><div style="display:grid;grid-template-columns:1fr 1fr;gap:6.4rem;align-items:center;"><div><p class="cl-label">{{ section.settings.s1_label | default: 'Por que revender Clenear' }}</p><h2 class="cl-h2">{{ section.settings.s1_heading | default: 'Linhas completas e suporte para crescer' }}</h2><p class="cl-lead">{{ section.settings.s1_text | default: 'Portfólio amplo, orientação técnica e condições comerciais para diferentes perfis.' }}</p><ul class="cl-auto__list" style="margin-top:2.4rem;">{%- for block in section.blocks -%}{%- if block.type == 'benefit' -%}<li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>{%- endif -%}{%- endfor -%}</ul></div><div style="background:var(--cl-green-soft);border-radius:var(--cl-radius-xl);padding:4rem;display:flex;flex-direction:column;gap:2rem;">{%- for block in section.blocks -%}{%- if block.type == 'segment' -%}<div style="background:#fff;border-radius:var(--cl-radius);padding:2rem 2.4rem;display:flex;align-items:center;gap:1.6rem;box-shadow:var(--cl-shadow-sm);" {{ block.shopify_attributes }}><span style="font-size:2.4rem;flex-shrink:0;">{{ block.settings.emoji }}</span><div><div style="font-weight:800;font-size:1.65rem;color:var(--cl-ink);">{{ block.settings.title }}</div><div style="font-size:1.4rem;color:var(--cl-muted);margin-top:.3rem;">{{ block.settings.text }}</div></div></div>{%- endif -%}{%- endfor -%}</div></div></div></section>
<section class="cl-section cl-reseller cl-dark"><div class="cl-reseller__deco" aria-hidden="true"></div><div class="cl-wrap" style="position:relative;z-index:1;text-align:center;"><p class="cl-label" style="justify-content:center;">Dê o próximo passo</p><h2 class="cl-h2" style="color:#fff;max-width:64rem;margin:0 auto;">{{ section.settings.cta_heading | default: 'Pronto para começar a revender?' }}</h2><p class="cl-lead" style="max-width:56rem;margin:1.6rem auto 0;">{{ section.settings.cta_text | default: 'Atendemos em dias úteis.' }}</p><div class="cl-btn-row" style="justify-content:center;"><a href="{{ section.settings.cta_wa | default: 'https://api.whatsapp.com/send?phone=552732280140' }}" class="cl-btn cl-btn--whatsapp" target="_blank" rel="noopener">Chamar no WhatsApp</a><a href="/pages/contact" class="cl-btn cl-btn--ghost">Formulário</a></div>{%- if section.settings.phone != blank -%}<p style="margin-top:2.4rem;color:rgba(255,255,255,.45);font-size:1.4rem;">Ligue: <a href="tel:{{ section.settings.phone | remove: '(' | remove: ')' | remove: ' ' | remove: '-' }}" style="color:rgba(255,255,255,.7);font-weight:700;">{{ section.settings.phone }}</a></p>{%- endif -%}</div></section>
{% schema %}{"name":"Clenear: Revenda","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Seja um parceiro"},{"type":"text","id":"heading","label":"Título","default":"Revenda Clenear e expanda"},{"type":"textarea","id":"subtext","label":"Subtítulo","default":"Portfólio completo, suporte e condições para crescer."},{"type":"url","id":"cta_wa","label":"WhatsApp link"},{"type":"text","id":"s1_label","label":"Sec label","default":"Por que revender"},{"type":"text","id":"s1_heading","label":"Sec título","default":"Linhas completas e suporte"},{"type":"textarea","id":"s1_text","label":"Sec texto","default":"Portfólio amplo, orientação técnica e condições para diferentes perfis."},{"type":"text","id":"cta_heading","label":"CTA título","default":"Pronto para revender?"},{"type":"textarea","id":"cta_text","label":"CTA texto","default":"Equipe atende em dias úteis."},{"type":"text","id":"phone","label":"Telefone","default":"(27) 3228-0140"}],"blocks":[{"type":"benefit","name":"Benefício","settings":[{"type":"text","id":"text","label":"Texto"}]},{"type":"segment","name":"Segmento","settings":[{"type":"text","id":"emoji","label":"Emoji","default":"📦"},{"type":"text","id":"title","label":"Título"},{"type":"text","id":"text","label":"Descrição"}]}],"presets":[{"name":"Clenear Revenda","blocks":[{"type":"benefit","settings":{"text":"Linhas completas por segmento"}},{"type":"benefit","settings":{"text":"Orientação técnica e suporte de vendas"}},{"type":"benefit","settings":{"text":"Condições para diferentes volumes"}},{"type":"benefit","settings":{"text":"Parceria de longo prazo"}},{"type":"segment","settings":{"emoji":"🚗","title":"Automotivo","text":"Linha+ completa"}},{"type":"segment","settings":{"emoji":"🧺","title":"Lavanderia","text":"Amaciantes e detergentes"}},{"type":"segment","settings":{"emoji":"🏢","title":"Corporativo","text":"Para empresas"}},{"type":"segment","settings":{"emoji":"🏭","title":"Industrial","text":"Alta concentração"}}]}]}{% endschema %}