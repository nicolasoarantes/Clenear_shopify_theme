{{ 'clenear-home-v2.css' | asset_url | stylesheet_tag }}
<style>.cl-contact-grid{display:grid;grid-template-columns:1fr 1.4fr;gap:6.4rem;align-items:start;}.cl-contact-info{display:flex;flex-direction:column;gap:2.4rem;}.cl-contact-card{background:#fff;border:1px solid var(--cl-border);border-radius:var(--cl-radius);padding:2.4rem;display:flex;gap:1.6rem;align-items:flex-start;box-shadow:var(--cl-shadow-sm);}.cl-contact-card__icon{width:4.4rem;height:4.4rem;background:var(--cl-green-soft);border-radius:var(--cl-radius-sm);display:grid;place-items:center;font-size:1.8rem;flex-shrink:0;}.cl-contact-card__label{font-size:1.2rem;font-weight:800;letter-spacing:.08em;text-transform:uppercase;color:var(--cl-green);margin-bottom:.4rem;}.cl-contact-card__value{font-size:1.65rem;font-weight:700;color:var(--cl-ink);}.cl-contact-card__sub{font-size:1.35rem;color:var(--cl-muted);margin-top:.3rem;}.cl-contact-form-wrap{background:#fff;border:1px solid var(--cl-border);border-radius:var(--cl-radius-xl);padding:4rem;box-shadow:var(--cl-shadow-md);}.cl-field{margin-bottom:1.6rem;}.cl-field label{display:block;font-size:1.3rem;font-weight:700;color:var(--cl-ink-mid);margin-bottom:.6rem;}.cl-field input,.cl-field select,.cl-field textarea{width:100%;border:1.5px solid var(--cl-border);border-radius:var(--cl-radius-sm);padding:1.2rem 1.4rem;font-size:1.55rem;color:var(--cl-ink);background:#fff;transition:border-color 180ms ease;outline:none;font-family:inherit;box-sizing:border-box;}.cl-field input:focus,.cl-field select:focus,.cl-field textarea:focus{border-color:var(--cl-green);}.cl-field textarea{resize:vertical;min-height:12rem;}.cl-field--row{display:grid;grid-template-columns:1fr 1fr;gap:1.2rem;}@media(max-width:1024px){.cl-contact-grid{grid-template-columns:1fr;}}@media(max-width:749px){.cl-contact-form-wrap{padding:2.4rem;}.cl-field--row{grid-template-columns:1fr;}}</style>
<div class="cl-hero cl-dark" style="padding:6.4rem 0 5.6rem;min-height:auto;"><div class="cl-hero__bg-shape cl-hero__bg-shape--1" aria-hidden="true"></div><div class="cl-wrap" style="position:relative;z-index:1;"><p class="cl-label">{{ section.settings.eyebrow | default: 'Fale com a gente' }}</p><h1 class="cl-hero__h1" style="max-width:64rem;">{{ section.settings.heading | default: 'Entre em contato com a equipe Clenear' }}</h1>{%- if section.settings.subtext != blank -%}<p class="cl-hero__sub">{{ section.settings.subtext }}</p>{%- endif -%}</div></div>
<section class="cl-section" style="background:var(--cl-gray-50);"><div class="cl-wrap"><div class="cl-contact-grid"><div class="cl-contact-info">{%- if section.settings.phone != blank -%}<div class="cl-contact-card"><div class="cl-contact-card__icon">📞</div><div><div class="cl-contact-card__label">Telefone</div><div class="cl-contact-card__value"><a href="tel:{{ section.settings.phone | remove: '(' | remove: ')' | remove: ' ' | remove: '-' }}" style="color:inherit;text-decoration:none;">{{ section.settings.phone }}</a></div><div class="cl-contact-card__sub">Dias úteis</div></div></div>{%- endif -%}{%- if section.settings.whatsapp != blank -%}<div class="cl-contact-card"><div class="cl-contact-card__icon">💬</div><div><div class="cl-contact-card__label">WhatsApp</div><div class="cl-contact-card__value"><a href="{{ section.settings.whatsapp }}" target="_blank" rel="noopener" style="color:var(--cl-green);text-decoration:none;">Chamar no WhatsApp</a></div><div class="cl-contact-card__sub">Resposta rápida</div></div></div>{%- endif -%}{%- if section.settings.email != blank -%}<div class="cl-contact-card"><div class="cl-contact-card__icon">✉️</div><div><div class="cl-contact-card__label">E-mail</div><div class="cl-contact-card__value"><a href="mailto:{{ section.settings.email }}" style="color:inherit;text-decoration:none;">{{ section.settings.email }}</a></div></div></div>{%- endif -%}{%- if section.settings.address != blank -%}<div class="cl-contact-card"><div class="cl-contact-card__icon">📍</div><div><div class="cl-contact-card__label">Endereço</div><div class="cl-contact-card__value" style="font-size:1.5rem;">{{ section.settings.address }}</div></div></div>{%- endif -%}<div style="background:var(--cl-green-dark);border-radius:var(--cl-radius);padding:2.4rem;color:#fff;"><div style="font-size:1.2rem;font-weight:800;letter-spacing:.08em;text-transform:uppercase;color:var(--cl-mint);margin-bottom:1rem;">Horário</div><div style="font-size:1.55rem;font-weight:700;">{{ section.settings.hours | default: 'Seg a Sex, 8h–17h' }}</div><div style="font-size:1.35rem;color:rgba(255,255,255,.65);margin-top:.4rem;">{{ section.settings.hours_note | default: 'Fora do horário, atendemos pelo WhatsApp' }}</div></div></div><div class="cl-contact-form-wrap"><h2 style="font-size:2.4rem;font-weight:900;letter-spacing:-.01em;color:var(--cl-ink);margin:0 0 .8rem;">{{ section.settings.form_heading | default: 'Envie sua mensagem' }}</h2><p style="font-size:1.55rem;color:var(--cl-muted);margin:0 0 2.8rem;">{{ section.settings.form_sub | default: 'Preencha e retornaremos em breve.' }}</p>{%- form 'contact', id: 'ContactForm' -%}{%- if form.posted_successfully? -%}<div style="background:var(--cl-green-soft);border:1.5px solid var(--cl-green);border-radius:var(--cl-radius-sm);padding:1.6rem 2rem;color:var(--cl-green-dark);font-weight:700;margin-bottom:2rem;">✓ Mensagem enviada! Retornaremos em breve.</div>{%- endif -%}<div class="cl-field--row"><div class="cl-field"><label for="ContactName">Nome *</label><input type="text" id="ContactName" name="contact[name]" required placeholder="Seu nome"></div><div class="cl-field"><label for="ContactCompany">Empresa</label><input type="text" id="ContactCompany" name="contact[company]" placeholder="Nome da empresa"></div></div><div class="cl-field--row"><div class="cl-field"><label for="ContactEmail">E-mail *</label><input type="email" id="ContactEmail" name="contact[email]" required placeholder="seu@email.com" value="{{ form.email }}"></div><div class="cl-field"><label for="ContactPhone">WhatsApp</label><input type="tel" id="ContactPhone" name="contact[phone]" placeholder="(XX) XXXXX-XXXX"></div></div><div class="cl-field"><label for="ContactCity">Cidade / Estado</label><input type="text" id="ContactCity" name="contact[city]" placeholder="Cidade — Estado"></div><div class="cl-field"><label for="ContactType">Assunto *</label><select id="ContactType" name="contact[type]" required><option value="">Selecione</option><option value="Orçamento">Solicitar orçamento</option><option value="Revenda">Interesse em revenda</option><option value="Dúvida técnica">Dúvida técnica</option><option value="Parceria">Parceria / Marca própria</option><option value="Outro">Outro</option></select></div><div class="cl-field"><label for="ContactMessage">Mensagem *</label><textarea id="ContactMessage" name="contact[body]" required placeholder="Como podemos ajudar?">{{ form.body }}</textarea></div><button type="submit" class="cl-btn cl-btn--primary" style="width:100%;justify-content:center;font-size:1.65rem;padding:1.6rem;">Enviar mensagem</button>{%- endform -%}</div></div></div></section>
{% schema %}{"name":"Clenear: Contato","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Fale com a gente"},{"type":"text","id":"heading","label":"Título","default":"Entre em contato"},{"type":"textarea","id":"subtext","label":"Subtítulo","default":"Orçamento, revenda ou dúvida técnica."},{"type":"text","id":"phone","label":"Telefone","default":"(27) 3228-0140"},{"type":"url","id":"whatsapp","label":"WhatsApp link"},{"type":"text","id":"email","label":"E-mail"},{"type":"textarea","id":"address","label":"Endereço","default":"Serra — Espírito Santo"},{"type":"text","id":"hours","label":"Horário","default":"Seg a Sex, 8h–17h"},{"type":"text","id":"hours_note","label":"Nota","default":"Fora do horário, atendemos pelo WhatsApp"},{"type":"text","id":"form_heading","label":"Form título","default":"Envie sua mensagem"},{"type":"text","id":"form_sub","label":"Form subtexto","default":"Preencha e retornaremos em breve."}],"presets":[{"name":"Clenear Contato"}]}{% endschema %}