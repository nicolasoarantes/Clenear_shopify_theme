{{ 'clenear-pages.css' | asset_url | stylesheet_tag }}
{{ 'clenear-pi.css' | asset_url | stylesheet_tag }}

<div class="cl-pi-cursor-glow" id="cl-pi-cursor" aria-hidden="true"></div>
<div class="cl-pi-cursor-inner" id="cl-pi-cursor-inner" aria-hidden="true"></div>
<div class="cl-pi-orbit-ring" id="cl-pi-orbit-ring" aria-hidden="true"></div>

<div class="cl-pg-page" id="pesquisa-inovacao">

  {%- comment -%} ===== HERO ===== {%- endcomment -%}
  <section class="cl-pi-hero" id="cl-pi-hero-section">
    <canvas class="cl-pi-hero__canvas" id="cl-pi-canvas" aria-hidden="true"></canvas>
    <div class="cl-pi-hero__overlay" aria-hidden="true"></div>
    <div class="cl-pg-wrap cl-pi-hero__wrap">
      <div class="cl-pi-hero__grid">

        <div class="cl-pi-hero__left cl-pg-fade">
          <div class="cl-pi-hero__badge">
            <span class="cl-pi-hero__badge-dot"></span>
            {{ section.settings.hero_badge | default: 'Laboratório próprio · Serra, ES' }}
          </div>
          <p class="cl-pg-eyebrow">{{ section.settings.hero_eyebrow | default: 'Pesquisa & Inovação' }}</p>
          <h1 class="cl-pg-h1">
            {{ section.settings.hero_title | default: 'Ciência e técnica no <em>desenvolvimento de cada fórmula</em>' }}
          </h1>
          <p class="cl-pg-lead">
            {{ section.settings.hero_subtitle | default: 'Cada produto Clenear nasce de um processo rigoroso de pesquisa, teste e validação — do laboratório ao mercado.' }}
          </p>
          <div class="cl-pg-btn-row">
            <a href="{{ section.settings.cta_wa_url | default: 'https://api.whatsapp.com/send?phone=552732280140&text=Ol%C3%A1!%20Vim%20pelo%20site%20da%20Clenear%20e%20gostaria%20de%20falar%20com%20o%20Setor%20T%C3%A9cnico.' }}"
               class="cl-pg-btn cl-pg-btn--wa" target="_blank" rel="noopener">
              {{ section.settings.cta_wa_label | default: 'Falar com o Setor Técnico' }}
            </a>
            <a href="{{ section.settings.cta2_url | default: '/pages/nossas-linhas' }}" class="cl-pg-btn cl-pg-btn--outline">
              {{ section.settings.cta2_label | default: 'Conheça Nossas Linhas' }}
            </a>
          </div>
        </div>

        <div class="cl-pi-hero__right cl-pg-fade cl-pg-fade--d2">
          <div class="cl-pi-panel">
            <div class="cl-pi-panel__header">
              <span class="cl-pi-panel__dot"></span>
              <span class="cl-pi-panel__dot"></span>
              <span class="cl-pi-panel__dot"></span>
              <span class="cl-pi-panel__title">lab.clenear · análise de fórmula</span>
            </div>
            <div class="cl-pi-panel__body">
              <div class="cl-pi-panel__metric">
                <span class="cl-pi-panel__lbl">Estabilidade de pH</span>
                <div class="cl-pi-panel__bar"><div class="cl-pi-panel__fill" style="--w:94%"></div></div>
                <span class="cl-pi-panel__val">94%</span>
              </div>
              <div class="cl-pi-panel__metric">
                <span class="cl-pi-panel__lbl">Performance em campo</span>
                <div class="cl-pi-panel__bar"><div class="cl-pi-panel__fill" style="--w:98%"></div></div>
                <span class="cl-pi-panel__val">98%</span>
              </div>
              <div class="cl-pi-panel__metric">
                <span class="cl-pi-panel__lbl">Biodegradabilidade</span>
                <div class="cl-pi-panel__bar"><div class="cl-pi-panel__fill" style="--w:100%"></div></div>
                <span class="cl-pi-panel__val">100%</span>
              </div>
              <div class="cl-pi-panel__metric">
                <span class="cl-pi-panel__lbl">Conformidade ANVISA</span>
                <div class="cl-pi-panel__bar"><div class="cl-pi-panel__fill" style="--w:100%"></div></div>
                <span class="cl-pi-panel__val">100%</span>
              </div>
            </div>
            <div class="cl-pi-panel__badges">
              <span>✓ ANVISA</span>
              <span>✓ Alto rendimento</span>
              <span>✓ Lab. próprio</span>
            </div>
            <div class="cl-pi-panel__stats">
              <div class="cl-pi-panel__stat">
                <strong>+18</strong><span>anos</span>
              </div>
              <div class="cl-pi-panel__stat-div" aria-hidden="true"></div>
              <div class="cl-pi-panel__stat">
                <strong>+50</strong><span>formulações</span>
              </div>
              <div class="cl-pi-panel__stat-div" aria-hidden="true"></div>
              <div class="cl-pi-panel__stat">
                <strong>100%</strong><span>interno</span>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
    <div class="cl-pi-hero__scroll-hint" aria-hidden="true"><span></span></div>
  </section>

  {%- comment -%} ===== PILARES ===== {%- endcomment -%}
  <section class="cl-pg-section cl-pg-section--alt" data-cursor-section>
    <div class="cl-pg-wrap">
      <div class="cl-pg-intro cl-pg-intro--center cl-pg-fade">
        <p class="cl-pg-eyebrow">{{ section.settings.pilares_eyebrow | default: 'Nossos pilares' }}</p>
        <h2 class="cl-pg-h2">{{ section.settings.pilares_title | default: 'Como <em>desenvolvemos</em> cada produto' }}</h2>
        <p class="cl-pg-lead cl-pg-lead--wide">{{ section.settings.pilares_subtitle | default: 'Quatro pilares guiam nosso processo de P&D — da concepção à validação final.' }}</p>
      </div>
      <div class="cl-pg-cards cl-pg-cards--4 cl-pg-fade cl-pg-fade--d1">
        {%- for block in section.blocks -%}
          {%- if block.type == 'pilar' -%}
            <div class="cl-pg-card cl-pi-card" {{ block.shopify_attributes }}>
              <div class="cl-pg-card__number">{{ block.settings.number | default: '01' }}</div>
              <div class="cl-pi-card__icon-wrap">
                <span class="cl-pg-card__icon" aria-hidden="true">{{ block.settings.icon }}</span>
              </div>
              <h3 class="cl-pg-card__title">{{ block.settings.title }}</h3>
              <p class="cl-pg-card__text">{{ block.settings.text }}</p>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
      <div class="cl-pg-scroll-dots" aria-hidden="true">
        <span></span><span></span><span></span><span></span>
      </div>
    </div>
  </section>

  {%- comment -%} ===== PROCESSO ===== {%- endcomment -%}
  <section class="cl-pg-section cl-pg-section--dark" data-cursor-section>
    <div class="cl-pg-wrap">
      <div class="cl-pg-split">
        <div class="cl-pg-fade">
          <p class="cl-pg-eyebrow">{{ section.settings.proc_eyebrow | default: 'Da ideia ao produto' }}</p>
          <h2 class="cl-pg-h2">{{ section.settings.proc_title | default: 'Um processo rigoroso de <em>desenvolvimento</em>' }}</h2>
          <p class="cl-pg-lead">{{ section.settings.proc_text | default: 'Nenhum produto chega ao mercado sem passar por fases estruturadas de pesquisa, formulação, testes de campo e validação de segurança.' }}</p>
          <ol class="cl-pi-timeline">
            {%- assign step_num = 1 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'processo_item' -%}
                <li class="cl-pi-tl-item" {{ block.shopify_attributes }}>
                  <span class="cl-pi-tl-num">{{ step_num }}</span>
                  <span class="cl-pi-tl-text">{{ block.settings.text }}</span>
                </li>
                {%- assign step_num = step_num | plus: 1 -%}
              {%- endif -%}
            {%- endfor -%}
          </ol>
        </div>
        <div class="cl-pg-split__media cl-pg-fade cl-pg-fade--d2">
          {%- if section.settings.proc_image != blank -%}
            {{ section.settings.proc_image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '400, 700, 800', sizes: '(min-width: 1024px) 44vw, 90vw', alt: 'Processo de P&D Clenear' }}
          {%- else -%}
            <div class="cl-pg-placeholder cl-pi-placeholder-glow">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2v-4M9 21H5a2 2 0 0 1-2-2v-4m0 0h18"/></svg>
              <span>Foto laboratório / processo (16:9)</span>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ===== PARCERIA TÉCNICA ===== {%- endcomment -%}
  <section class="cl-pg-section cl-pg-section--alt" data-cursor-section>
    <div class="cl-pg-wrap">
      <div class="cl-pg-split cl-pg-split--flip">
        <div class="cl-pg-split__media cl-pg-fade">
          {%- if section.settings.parceria_image != blank -%}
            {{ section.settings.parceria_image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '400, 700, 800', sizes: '(min-width: 1024px) 44vw, 90vw', alt: 'Parceria técnica Clenear' }}
          {%- else -%}
            <div class="cl-pg-placeholder cl-pi-placeholder-glow">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              <span>Foto reunião / parceria (16:9)</span>
            </div>
          {%- endif -%}
        </div>
        <div class="cl-pg-fade cl-pg-fade--d1">
          <p class="cl-pg-eyebrow">{{ section.settings.parceria_eyebrow | default: 'Desenvolvimento colaborativo' }}</p>
          <h2 class="cl-pg-h2">{{ section.settings.parceria_title | default: 'Formulamos sob medida para o <em>seu negócio</em>' }}</h2>
          <p class="cl-pg-lead">{{ section.settings.parceria_text | default: 'Seja para criar uma nova linha, adaptar uma formulação ou desenvolver um produto exclusivo, nosso time técnico trabalha ao seu lado em cada etapa.' }}</p>
          <ul class="cl-pg-split__list">
            {%- for block in section.blocks -%}
              {%- if block.type == 'parceria_item' -%}
                <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
          <div class="cl-pg-btn-row">
            <a href="{{ section.settings.cta_wa_url | default: 'https://api.whatsapp.com/send?phone=552732280140&text=Ol%C3%A1!%20Vim%20pelo%20site%20da%20Clenear%20e%20gostaria%20de%20falar%20com%20o%20Setor%20T%C3%A9cnico.' }}"
               class="cl-pg-btn cl-pg-btn--wa" target="_blank" rel="noopener">
              {{ section.settings.cta_wa_label | default: 'Falar com o Setor Técnico' }}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ===== MID CTA ===== {%- endcomment -%}
  <section class="cl-pg-section cl-pg-section--dark" data-cursor-section>
    <div class="cl-pg-wrap">
      <div class="cl-pg-mid-cta cl-pg-fade">
        <p class="cl-pg-eyebrow" style="text-align:center;">{{ section.settings.mid_cta_eyebrow | default: 'Vamos conversar?' }}</p>
        <h3>{{ section.settings.mid_cta_heading | default: 'Tem uma necessidade técnica específica?' }}</h3>
        <p>{{ section.settings.mid_cta_text | default: 'Nossa equipe de P&D está pronta para desenvolver a formulação ideal para o seu segmento.' }}</p>
        <div class="cl-pg-btn-row">
          <a href="{{ section.settings.cta_wa_url | default: 'https://api.whatsapp.com/send?phone=552732280140&text=Ol%C3%A1!%20Vim%20pelo%20site%20da%20Clenear%20e%20gostaria%20de%20falar%20com%20o%20Setor%20T%C3%A9cnico.' }}"
             class="cl-pg-btn cl-pg-btn--wa" target="_blank" rel="noopener">
            {{ section.settings.cta_wa_label | default: 'Falar com o Setor Técnico' }}
          </a>
          <a href="{{ section.settings.cta2_url | default: '/pages/nossas-linhas' }}" class="cl-pg-btn cl-pg-btn--outline">
            {{ section.settings.cta2_label | default: 'Conheça Nossas Linhas' }}
          </a>
        </div>
      </div>
    </div>
  </section>

</div>

<script src="{{ 'clenear-pi.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Pesquisa & Inovação",
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "text", "id": "hero_badge", "label": "Badge", "default": "Laboratório próprio · Serra, ES" },
    { "type": "text", "id": "hero_eyebrow", "label": "Eyebrow", "default": "Pesquisa & Inovação" },
    { "type": "text", "id": "hero_title", "label": "Título (use <em> para destaque)", "default": "Ciência e técnica no <em>desenvolvimento de cada fórmula</em>" },
    { "type": "textarea", "id": "hero_subtitle", "label": "Subtítulo" },
    { "type": "text", "id": "cta_wa_label", "label": "CTA WhatsApp", "default": "Falar com o Setor Técnico" },
    { "type": "url", "id": "cta_wa_url", "label": "Link WhatsApp" },
    { "type": "text", "id": "cta2_label", "label": "CTA secundário", "default": "Conheça Nossas Linhas" },
    { "type": "url", "id": "cta2_url", "label": "Link CTA secundário" },
    { "type": "header", "content": "Seção: Pilares" },
    { "type": "text", "id": "pilares_eyebrow", "label": "Eyebrow", "default": "Nossos pilares" },
    { "type": "text", "id": "pilares_title", "label": "Título", "default": "Como <em>desenvolvemos</em> cada produto" },
    { "type": "textarea", "id": "pilares_subtitle", "label": "Subtítulo" },
    { "type": "header", "content": "Seção: Processo" },
    { "type": "text", "id": "proc_eyebrow", "label": "Eyebrow", "default": "Da ideia ao produto" },
    { "type": "text", "id": "proc_title", "label": "Título", "default": "Um processo rigoroso de <em>desenvolvimento</em>" },
    { "type": "textarea", "id": "proc_text", "label": "Texto" },
    { "type": "image_picker", "id": "proc_image", "label": "Imagem processo (16:9)" },
    { "type": "header", "content": "Seção: Parceria técnica" },
    { "type": "text", "id": "parceria_eyebrow", "label": "Eyebrow", "default": "Desenvolvimento colaborativo" },
    { "type": "text", "id": "parceria_title", "label": "Título", "default": "Formulamos sob medida para o <em>seu negócio</em>" },
    { "type": "textarea", "id": "parceria_text", "label": "Texto" },
    { "type": "image_picker", "id": "parceria_image", "label": "Imagem parceria (16:9)" },
    { "type": "header", "content": "Mid CTA" },
    { "type": "text", "id": "mid_cta_eyebrow", "label": "Eyebrow", "default": "Vamos conversar?" },
    { "type": "text", "id": "mid_cta_heading", "label": "Título", "default": "Tem uma necessidade técnica específica?" },
    { "type": "textarea", "id": "mid_cta_text", "label": "Texto", "default": "Nossa equipe de P&D está pronta para desenvolver a formulação ideal para o seu segmento." }
  ],
  "blocks": [
    {
      "type": "pilar",
      "name": "Pilar",
      "settings": [
        { "type": "text", "id": "number", "label": "Número", "default": "01" },
        { "type": "text", "id": "icon", "label": "Emoji", "default": "🔬" },
        { "type": "text", "id": "title", "label": "Título" },
        { "type": "textarea", "id": "text", "label": "Descrição" }
      ]
    },
    {
      "type": "processo_item",
      "name": "Item do processo",
      "settings": [
        { "type": "text", "id": "text", "label": "Texto do passo" }
      ]
    },
    {
      "type": "parceria_item",
      "name": "Item de parceria",
      "settings": [
        { "type": "text", "id": "text", "label": "Texto do item" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Clenear: Pesquisa PI",
      "blocks": [
        { "type": "pilar", "settings": { "number": "01", "icon": "🔬", "title": "Pesquisa e formulação", "text": "Cada fórmula começa em laboratório próprio, com testes rigorosos de pH, viscosidade e performance antes de sair para o mercado." } },
        { "type": "pilar", "settings": { "number": "02", "icon": "🧪", "title": "Matérias-primas selecionadas", "text": "Trabalhamos apenas com fornecedores certificados. Cada insumo passa por análise de qualidade antes de entrar na linha de produção." } },
        { "type": "pilar", "settings": { "number": "03", "icon": "🎯", "title": "Eficiência e uso consciente", "text": "Produtos concentrados e de alto rendimento, pensados para entregar resultado com melhor aproveitamento e uso responsável em cada aplicação." } },
        { "type": "pilar", "settings": { "number": "04", "icon": "📋", "title": "Validação e conformidade", "text": "Todos os produtos são testados para conformidade com normas ANVISA e regulatórias do setor de limpeza profissional." } },
        { "type": "processo_item", "settings": { "text": "Identificação da necessidade técnica com o cliente" } },
        { "type": "processo_item", "settings": { "text": "Pesquisa de matérias-primas e formulação em laboratório" } },
        { "type": "processo_item", "settings": { "text": "Testes de desempenho, estabilidade e segurança" } },
        { "type": "processo_item", "settings": { "text": "Ajustes finos e validação com uso real em campo" } },
        { "type": "processo_item", "settings": { "text": "Registro, conformidade regulatória e escala de produção" } },
        { "type": "parceria_item", "settings": { "text": "Desenvolvimento de fórmulas exclusivas para sua marca" } },
        { "type": "parceria_item", "settings": { "text": "Suporte técnico contínuo e treinamento de equipe" } },
        { "type": "parceria_item", "settings": { "text": "Adaptação de produtos para segmentos específicos" } },
        { "type": "parceria_item", "settings": { "text": "Consultoria em diluição, uso e dosagem correta" } }
      ]
    }
  ]
}
{% endschema %}