{{ 'clenear-pages.css' | asset_url | stylesheet_tag }}

<div class="cl-pg-page" id="pesquisa-inovacao">

  {%- comment -%} ===== HERO — THREE.JS ===== {%- endcomment -%}
  <section class="cl-pi-hero">
    <canvas class="cl-pi-hero__canvas" id="cl-pi-canvas" aria-hidden="true"></canvas>
    <div class="cl-pg-wrap" style="width:100%;">
      <div class="cl-pi-hero__content cl-pg-fade">
        <div class="cl-pi-hero__badge">
          Laboratório próprio · Serra, ES
        </div>
        <p class="cl-pg-eyebrow" style="text-align:center;">{{ section.settings.hero_eyebrow | default: 'Pesquisa & Inovação' }}</p>
        <h1 class="cl-pg-h1" style="text-align:center;margin-bottom:2rem;max-width:80rem;margin-left:auto;margin-right:auto;">{{ section.settings.hero_title | default: 'Ciência e técnica no <em>desenvolvimento de cada fórmula</em>' }}</h1>
        <p class="cl-pg-lead" style="text-align:center;margin-left:auto;margin-right:auto;">{{ section.settings.hero_subtitle | default: 'Cada produto Clenear nasce de um processo rigoroso de pesquisa, teste e validação. Investimos em P&D para entregar formulações que se destacam em desempenho, segurança e sustentabilidade.' }}</p>
        <div class="cl-pg-btn-row" style="justify-content:center;">
          <a href="{{ section.settings.cta_wa_url | default: 'https://api.whatsapp.com/send?phone=552732280140&text=Ol%C3%A1!%20Vim%20pelo%20site%20da%20Clenear%20e%20gostaria%20de%20conversar%20sobre%20P%26D%20e%20formula%C3%A7%C3%B5es.' }}" class="cl-pg-btn cl-pg-btn--wa" target="_blank" rel="noopener">
            {{ section.settings.cta_wa_label | default: 'Falar com equipe técnica' }}
          </a>
          <a href="{{ section.settings.cta2_url | default: '/pages/contato' }}" class="cl-pg-btn cl-pg-btn--outline">
            {{ section.settings.cta2_label | default: 'Formulário técnico' }}
          </a>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ===== PILARES ===== {%- endcomment -%}
  <section class="cl-pg-section cl-pg-section--alt">
    <div class="cl-pg-wrap">
      <div class="cl-pg-intro cl-pg-intro--center cl-pg-fade">
        <p class="cl-pg-eyebrow">{{ section.settings.pilares_eyebrow | default: 'Nossos pilares' }}</p>
        <h2 class="cl-pg-h2">{{ section.settings.pilares_title | default: 'Como desenvolvemos <em>cada produto</em>' }}</h2>
        <p class="cl-pg-lead cl-pg-lead--wide">{{ section.settings.pilares_subtitle | default: 'Quatro pilares guiam o nosso processo de pesquisa e desenvolvimento desde a concepção até o produto final.' }}</p>
      </div>
      <div class="cl-pg-cards cl-pg-cards--4 cl-pg-fade cl-pg-fade--d1">
        {%- for block in section.blocks -%}
          {%- if block.type == 'pilar' -%}
            <div class="cl-pg-card" {{ block.shopify_attributes }}>
              <div class="cl-pg-card__number">{{ block.settings.number | default: '01' }}</div>
              <div class="cl-pg-card__icon">{{ block.settings.icon }}</div>
              <h3 class="cl-pg-card__title">{{ block.settings.title }}</h3>
              <p class="cl-pg-card__text">{{ block.settings.text }}</p>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
      <div class="cl-pg-scroll-dots" aria-hidden="true">
        <span></span><span></span><span></span><span></span>
      </div>
    </div>
  </section>

  {%- comment -%} ===== PROCESSO DE DESENVOLVIMENTO ===== {%- endcomment -%}
  <section class="cl-pg-section cl-pg-section--dark">
    <div class="cl-pg-wrap">
      <div class="cl-pg-split">
        <div class="cl-pg-fade">
          <p class="cl-pg-eyebrow">{{ section.settings.proc_eyebrow | default: 'Da ideia ao produto' }}</p>
          <h2 class="cl-pg-h2">{{ section.settings.proc_title | default: 'Um processo <em>rigoroso</em> de desenvolvimento' }}</h2>
          <p class="cl-pg-lead">{{ section.settings.proc_text | default: 'Nenhum produto chega ao mercado sem passar por fases estruturadas de pesquisa, formulação, testes de campo e validação de segurança.' }}</p>
          <ul class="cl-pg-split__list">
            {%- for block in section.blocks -%}
              {%- if block.type == 'processo_item' -%}
                <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </div>
        <div class="cl-pg-split__media cl-pg-fade cl-pg-fade--d2">
          {%- if section.settings.proc_image != blank -%}
            {{ section.settings.proc_image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '400, 700, 800', sizes: '(min-width: 1024px) 44vw, 90vw', alt: 'Processo de P&D Clenear' }}
          {%- else -%}
            <div class="cl-pg-placeholder">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
              <span>Foto laboratório / desenvolvimento<br>(16:9)</span>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ===== PARCERIA TÉCNICA ===== {%- endcomment -%}
  <section class="cl-pg-section cl-pg-section--alt">
    <div class="cl-pg-wrap">
      <div class="cl-pg-split cl-pg-split--flip">
        <div class="cl-pg-split__media cl-pg-fade">
          {%- if section.settings.parceria_image != blank -%}
            {{ section.settings.parceria_image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '400, 700, 800', sizes: '(min-width: 1024px) 44vw, 90vw', alt: 'Parceria técnica Clenear' }}
          {%- else -%}
            <div class="cl-pg-placeholder">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
              <span>Foto reunião ou parceria<br>(16:9)</span>
            </div>
          {%- endif -%}
        </div>
        <div class="cl-pg-fade cl-pg-fade--d1">
          <p class="cl-pg-eyebrow">{{ section.settings.parceria_eyebrow | default: 'Desenvolvimento colaborativo' }}</p>
          <h2 class="cl-pg-h2">{{ section.settings.parceria_title | default: 'Formulamos sob medida <em>para o seu negócio</em>' }}</h2>
          <p class="cl-pg-lead">{{ section.settings.parceria_text | default: 'Seja para criar uma nova linha, adaptar uma formulação ou desenvolver um produto exclusivo, nosso time técnico trabalha ao seu lado em cada etapa.' }}</p>
          <ul class="cl-pg-split__list">
            {%- for block in section.blocks -%}
              {%- if block.type == 'parceria_item' -%}
                <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
          <div class="cl-pg-btn-row">
            <a href="{{ section.settings.cta_wa_url | default: 'https://api.whatsapp.com/send?phone=552732280140&text=Ol%C3%A1!%20Vim%20pelo%20site%20da%20Clenear%20e%20gostaria%20de%20conversar%20sobre%20desenvolvimento%20de%20f%C3%B3rmula%20personalizada.' }}" class="cl-pg-btn cl-pg-btn--wa" target="_blank" rel="noopener">
              Falar sobre parceria técnica
            </a>
          </div>
        </div>
      </div>

      {%- comment -%} MID CTA {%- endcomment -%}
      <div class="cl-pg-mid-cta cl-pg-fade">
        <h3>{{ section.settings.mid_cta_heading | default: 'Tem uma necessidade técnica específica?' }}</h3>
        <p>{{ section.settings.mid_cta_text | default: 'Nossa equipe de P&D está pronta para desenvolver a formulação ideal para o seu segmento e aplicação.' }}</p>
        <div class="cl-pg-btn-row">
          <a href="{{ section.settings.cta_wa_url | default: 'https://api.whatsapp.com/send?phone=552732280140&text=Ol%C3%A1!%20Vim%20pelo%20site%20da%20Clenear%20e%20gostaria%20de%20falar%20com%20a%20equipe%20t%C3%A9cnica.' }}" class="cl-pg-btn cl-pg-btn--wa" target="_blank" rel="noopener">
            {{ section.settings.cta_wa_label | default: 'Falar com equipe técnica' }}
          </a>
          <a href="{{ section.settings.cta2_url | default: '/pages/contato' }}" class="cl-pg-btn cl-pg-btn--outline">
            {{ section.settings.cta2_label | default: 'Formulário técnico' }}
          </a>
        </div>
      </div>
    </div>
  </section>

</div>

<script>
/* ── Three.js particle hero ── */
(function () {
  var canvas = document.getElementById('cl-pi-canvas');
  if (!canvas) return;

  var THREE;
  var scene, camera, renderer, particles, positions, velocities;
  var mouse = { x: 0, y: 0 };
  var PARTICLE_COUNT = 120;
  var active = false;
  var animFrame;

  function init(T) {
    THREE = T;
    scene = new THREE.Scene();
    camera = new THREE.PerspectiveCamera(60, canvas.clientWidth / canvas.clientHeight, 0.1, 1000);
    camera.position.z = 80;

    renderer = new THREE.WebGLRenderer({ canvas: canvas, alpha: true, antialias: false });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5));
    renderer.setSize(canvas.clientWidth, canvas.clientHeight);
    renderer.setClearColor(0x000000, 0);

    var geo = new THREE.BufferGeometry();
    var pos = new Float32Array(PARTICLE_COUNT * 3);
    var col = new Float32Array(PARTICLE_COUNT * 3);
    positions = [];
    velocities = [];

    for (var i = 0; i < PARTICLE_COUNT; i++) {
      var x = (Math.random() - 0.5) * 140;
      var y = (Math.random() - 0.5) * 80;
      var z = (Math.random() - 0.5) * 40;
      pos[i * 3] = x; pos[i * 3 + 1] = y; pos[i * 3 + 2] = z;
      positions.push({ x: x, y: y, z: z, ox: x, oy: y });
      velocities.push({ vx: (Math.random() - 0.5) * 0.015, vy: (Math.random() - 0.5) * 0.015, phase: Math.random() * Math.PI * 2 });
      /* teal or white */
      if (Math.random() > 0.35) {
        col[i * 3] = 0.114; col[i * 3 + 1] = 0.431; col[i * 3 + 2] = 0.353; /* #1D6E5A */
      } else {
        col[i * 3] = 1; col[i * 3 + 1] = 1; col[i * 3 + 2] = 1;
      }
    }

    geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
    geo.setAttribute('color', new THREE.BufferAttribute(col, 3));

    var mat = new THREE.PointsMaterial({
      size: 0.6,
      vertexColors: true,
      transparent: true,
      opacity: 0.45,
      sizeAttenuation: true
    });

    particles = new THREE.Points(geo, mat);
    scene.add(particles);

    window.addEventListener('resize', onResize);
    canvas.ownerDocument.addEventListener('mousemove', onMouse);
    active = true;
    animate(0);
  }

  function onResize() {
    var w = canvas.clientWidth, h = canvas.clientHeight;
    camera.aspect = w / h;
    camera.updateProjectionMatrix();
    renderer.setSize(w, h);
  }

  function onMouse(e) {
    var rect = canvas.getBoundingClientRect();
    mouse.x = ((e.clientX - rect.left) / rect.width - 0.5) * 140;
    mouse.y = -((e.clientY - rect.top) / rect.height - 0.5) * 80;
  }

  function animate(t) {
    if (!active) return;
    animFrame = requestAnimationFrame(animate);
    var pos = particles.geometry.attributes.position.array;
    var REPEL = 150 * 150; /* influence radius² in world-ish units */

    for (var i = 0; i < PARTICLE_COUNT; i++) {
      var vel = velocities[i];
      var p = positions[i];

      /* sinusoidal drift */
      p.x = p.ox + Math.sin(t * 0.0004 + vel.phase) * 2.5;
      p.y = p.oy + Math.cos(t * 0.0003 + vel.phase) * 1.8;

      /* mouse repulsion (screen-space approximation) */
      var dx = p.x - mouse.x * 0.8;
      var dy = p.y - mouse.y * 0.8;
      var dist2 = dx * dx + dy * dy;
      if (dist2 < REPEL && dist2 > 0.01) {
        var force = (1 - dist2 / REPEL) * 0.18;
        p.x += (dx / Math.sqrt(dist2)) * force;
        p.y += (dy / Math.sqrt(dist2)) * force;
      }

      pos[i * 3] = p.x;
      pos[i * 3 + 1] = p.y;
      pos[i * 3 + 2] = p.z;
    }
    particles.geometry.attributes.position.needsUpdate = true;
    renderer.render(scene, camera);
  }

  /* Intersection Observer — pause when off-screen */
  var hero = canvas.parentElement;
  if ('IntersectionObserver' in window) {
    var ioHero = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) {
          if (!active && THREE) { active = true; animate(performance.now()); }
        } else {
          active = false;
          if (animFrame) cancelAnimationFrame(animFrame);
        }
      });
    }, { threshold: 0 });
    ioHero.observe(hero);
  }

  /* Load Three.js from CDN */
  var s = document.createElement('script');
  s.src = 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';
  s.crossOrigin = 'anonymous';
  s.onload = function () { init(window.THREE); };
  s.onerror = function () { /* graceful fallback — hero renders without canvas */ };
  document.head.appendChild(s);
})();

/* ── Scroll fade-in ── */
(function () {
  var fades = document.querySelectorAll('#pesquisa-inovacao .cl-pg-fade');
  if ('IntersectionObserver' in window) {
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
      });
    }, { threshold: 0.1 });
    fades.forEach(function (el) { io.observe(el); });
  } else {
    fades.forEach(function (el) { el.classList.add('is-visible'); });
  }
})();
</script>

