{{ 'clenear-home-v2.css' | asset_url | stylesheet_tag }}
<div class="cl-hero cl-dark" style="padding:7.2rem 0 6.4rem;min-height:auto;"><div class="cl-hero__bg-shape cl-hero__bg-shape--1" aria-hidden="true"></div><div class="cl-hero__bg-shape cl-hero__bg-shape--2" aria-hidden="true"></div><div class="cl-wrap" style="position:relative;z-index:1;"><p class="cl-label">{{ section.settings.eyebrow | default: 'Quem é a Clenear' }}</p><h1 class="cl-hero__h1" style="max-width:72rem;">{{ section.settings.heading | default: 'Indústria capixaba comprometida com qualidade e parceria' }}</h1>{%- if section.settings.subtext != blank -%}<p class="cl-hero__sub">{{ section.settings.subtext }}</p>{%- endif -%}</div></div>
<section class="cl-section cl-about" style="background:#fff;"><div class="cl-wrap"><div class="cl-about__grid"><div><p class="cl-label">{{ section.settings.s1_label | default: 'Nossa história' }}</p><h2 class="cl-h2">{{ section.settings.s1_heading | default: 'Desde 2006 entregando qualidade' }}</h2><p class="cl-lead">{{ section.settings.s1_text | default: 'A Clenear é uma indústria capixaba especializada no desenvolvimento de saneantes, aromatizantes e soluções de limpeza profissional.' }}</p>{%- if section.settings.purpose != blank -%}<blockquote style="margin:2.8rem 0 0;padding:2rem 2.4rem;border-left:4px solid var(--cl-green);background:var(--cl-green-soft);border-radius:0 var(--cl-radius-sm) var(--cl-radius-sm) 0;"><p style="font-size:1.7rem;line-height:1.6;color:var(--cl-ink-mid);font-style:italic;margin:0;">"{{ section.settings.purpose }}"</p></blockquote>{%- endif -%}<div class="cl-about__stats">{%- for block in section.blocks -%}{%- if block.type == 'stat' -%}<div {{ block.shopify_attributes }}><div class="cl-about__stat-num">{{ block.settings.value }}</div><div class="cl-about__stat-label">{{ block.settings.label }}</div></div>{%- endif -%}{%- endfor -%}</div></div><div class="cl-about__img-wrap"><div class="cl-about__img-main">{%- if section.settings.image != blank -%}{{ section.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '400,600,800', sizes: '(min-width:1024px) 40vw, 90vw', alt: 'Equipe Clenear' }}{%- else -%}<div style="width:100%;height:100%;background:linear-gradient(160deg,#EBF7F0,#D4E8DB);display:flex;align-items:center;justify-content:center;color:var(--cl-muted);font-size:1.5rem;padding:3.2rem;text-align:center;">Adicione uma foto da equipe</div>{%- endif -%}</div><div class="cl-about__img-accent"><strong style="color:var(--cl-mint);display:block;font-size:2.8rem;font-weight:900;line-height:1;">2006</strong><span style="font-size:1.3rem;opacity:.8;margin-top:.3rem;display:block;">fundação da Clenear</span></div></div></div></div></section>
<section class="cl-section" style="background:var(--cl-gray-50);"><div class="cl-wrap"><div class="cl-section-head"><p class="cl-label" style="justify-content:center;">{{ section.settings.s2_label | default: 'Nossos valores' }}</p><h2 class="cl-h2">{{ section.settings.s2_heading | default: 'O que guia cada decisão da Clenear' }}</h2></div><div class="cl-sol-grid">{%- for block in section.blocks -%}{%- if block.type == 'value' -%}<div class="cl-sol-card" style="cursor:default;" {{ block.shopify_attributes }}><div class="cl-sol-card__icon" aria-hidden="true">{{ block.settings.emoji | default: '✓' }}</div><h3 class="cl-sol-card__title">{{ block.settings.title }}</h3><p class="cl-sol-card__text">{{ block.settings.text }}</p></div>{%- endif -%}{%- endfor -%}</div></div></section>
<section class="cl-final-cta cl-dark" style="padding:6.4rem 0;"><div class="cl-final-cta__bg" aria-hidden="true"></div><div class="cl-wrap cl-final-cta__inner"><h2 class="cl-h2" style="color:#fff;">{{ section.settings.cta_heading | default: 'Quer conhecer mais a Clenear?' }}</h2><p class="cl-lead" style="color:rgba(255,255,255,.65);max-width:56rem;margin:1.6rem auto 0;">{{ section.settings.cta_text | default: 'Entre em contato com nossa equipe.' }}</p><div class="cl-btn-row" style="justify-content:center;"><a href="{{ section.settings.cta_wa | default: 'https://api.whatsapp.com/send?phone=552732280140' }}" class="cl-btn cl-btn--whatsapp" target="_blank" rel="noopener">Falar no WhatsApp</a><a href="/pages/revenda" class="cl-btn cl-btn--white">Quero revender</a></div></div></section>
{% schema %}{"name":"Clenear: Sobre","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Quem é a Clenear"},{"type":"text","id":"heading","label":"Título","default":"Indústria capixaba comprometida"},{"type":"textarea","id":"subtext","label":"Subtítulo","default":"Desde 2006 desenvolvendo soluções para empresas e parceiros."},{"type":"text","id":"s1_label","label":"Sec história label","default":"Nossa história"},{"type":"text","id":"s1_heading","label":"Sec história título","default":"Desde 2006 entregando qualidade"},{"type":"textarea","id":"s1_text","label":"Sec história texto","default":"A Clenear é especializada em saneantes, aromatizantes e soluções de limpeza profissional."},{"type":"textarea","id":"purpose","label":"Propósito","default":"Oferecer soluções eficazes e produtos de alta qualidade que enriquecem a vida dos nossos clientes."},{"type":"image_picker","id":"image","label":"Foto equipe"},{"type":"text","id":"s2_label","label":"Sec valores label","default":"Nossos valores"},{"type":"text","id":"s2_heading","label":"Sec valores título","default":"O que guia cada decisão"},{"type":"text","id":"cta_heading","label":"CTA título","default":"Quer conhecer mais?"},{"type":"textarea","id":"cta_text","label":"CTA texto","default":"Entre em contato ou descubra como revender."},{"type":"url","id":"cta_wa","label":"WhatsApp link"}],"blocks":[{"type":"stat","name":"Stat","settings":[{"type":"text","id":"value","label":"Número"},{"type":"text","id":"label","label":"Label"}]},{"type":"value","name":"Valor","settings":[{"type":"text","id":"emoji","label":"Emoji","default":"✓"},{"type":"text","id":"title","label":"Título"},{"type":"textarea","id":"text","label":"Texto"}]}],"presets":[{"name":"Clenear Sobre","blocks":[{"type":"stat","settings":{"value":"+18 anos","label":"de experiência"}},{"type":"stat","settings":{"value":"+50","label":"produtos"}},{"type":"stat","settings":{"value":"ES BR","label":"todo o país"}},{"type":"stat","settings":{"value":"B2B","label":"foco empresarial"}},{"type":"value","settings":{"emoji":"🎯","title":"Qualidade","text":"Rigor técnico e consistência em cada produto."}},{"type":"value","settings":{"emoji":"🤝","title":"Parceria","text":"Relações de longo prazo baseadas em confiança."}},{"type":"value","settings":{"emoji":"🌿","title":"Responsabilidade","text":"Fórmulas seguras com consciência ambiental."}}]}]}{% endschema %}