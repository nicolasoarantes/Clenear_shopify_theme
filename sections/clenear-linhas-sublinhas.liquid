        <h3 class="cl-sl__line-h3">Domissanitária</h3>
        <p class="cl-sl__line-desc">Produtos para limpeza, higienização, desinfecção e perfumação de ambientes comerciais, residenciais, coletivos e institucionais.</p>
        {%- capture m -%}Olá! Vim pela página de Linhas da Clenear e tenho interesse na Linha Domissanitária. Pode me enviar mais informações?{%- endcapture -%}
        <a class="cl-sl__line-wa" href="{{ wa_base }}{{ m | url_encode }}" target="_blank" rel="noopener">Falar sobre essa linha</a>
      </div>
    </div>
    <div class="cl-sl__sub-label">Sublinhas <span>— selecione para ver detalhes</span></div>
    <div class="cl-sl__md" data-md="domissanitaria">
      <ul class="cl-sl__md-list" role="listbox" aria-label="Sublinhas Domissanitária">
        <li class="cl-sl__md-item" role="option" data-idx="0" data-search="Cloro e desinfecção higienização superfícies água sanitária álcool pinho pastilha pedra sanitária"><span class="cl-sl__md-num">01</span><span class="cl-sl__md-name">Cloro e desinfecção</span><svg class="cl-sl__md-arr" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 3l5 5-5 5"/></svg></li>
        <li class="cl-sl__md-item" role="option" data-idx="1" data-search="Limpadores perfumados piso ambiente TOP Goclean higienizador"><span class="cl-sl__md-num">02</span><span class="cl-sl__md-name">Limpadores perfumados</span><svg class="cl-sl__md-arr" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 3l5 5-5 5"/></svg></li>
        <li class="cl-sl__md-item" role="option" data-idx="2" data-search="Limpadores multiuso superfícies Facilita Goclean cremoso"><span class="cl-sl__md-num">03</span><span class="cl-sl__md-name">Limpadores multiuso</span><svg class="cl-sl__md-arr" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 3l5 5-5 5"/></svg></li>
        <li class="cl-sl__md-item" role="option" data-idx="3" data-search="Detergentes louça coco limão neutro glicerinado Master Clean"><span class="cl-sl__md-num">04</span><span class="cl-sl__md-name">Detergentes</span><svg class="cl-sl__md-arr" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 3l5 5-5 5"/></svg></li>
        <li class="cl-sl__md-item" role="option" data-idx="4" data-search="Sabão líquido em pó barra Omega MultiAção espuma limpeza pesada"><span class="cl-sl__md-num">05</span><span class="cl-sl__md-name">Sabão líquido, em pó e barra</span><svg class="cl-sl__md-arr" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 3l5 5-5 5"/></svg></li>
        <li class="cl-sl__md-item" role="option" data-idx="5" data-search="Aromatizantes ambiente perfume difusor refil Stigma Intense"><span class="cl-sl__md-num">06</span><span class="cl-sl__md-name">Aromatizantes</span><svg class="cl-sl__md-arr" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 3l5 5-5 5"/></svg></li>
      </ul>
