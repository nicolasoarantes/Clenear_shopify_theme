<style>
.cl-sl{background:#071d18;color:#fff;padding:clamp(56px,8vw,104px) 0;overflow:hidden}
.cl-sl__wrap{max-width:1200px;margin:0 auto;padding:0 clamp(16px,4vw,40px)}
.cl-sl__header{text-align:center;max-width:720px;margin:0 auto clamp(36px,5vw,56px)}
.cl-sl__ew{color:#4dd1b0;font-size:11px;font-weight:800;letter-spacing:.14em;text-transform:uppercase;margin:0 0 12px}
.cl-sl__h2{font-size:clamp(32px,4.5vw,58px);font-weight:900;line-height:1.05;letter-spacing:-.02em;margin:0 0 16px;color:#fff}
.cl-sl__h2 span{color:#4dd1b0}
.cl-sl__lead{color:rgba(255,255,255,.68);font-size:clamp(15px,1.7vw,18px);line-height:1.65;margin:0}
.cl-sl__tabs{display:flex;gap:8px;margin:0 0 36px;overflow-x:auto;scrollbar-width:none;-webkit-overflow-scrolling:touch;padding-bottom:4px}
.cl-sl__tabs::-webkit-scrollbar{display:none}
.cl-sl__tab{flex-shrink:0;display:inline-flex;align-items:center;gap:6px;padding:11px 20px;border-radius:999px;border:1.5px solid rgba(255,255,255,.14);background:rgba(255,255,255,.05);color:rgba(255,255,255,.72);font-size:14px;font-weight:700;cursor:pointer;transition:all 180ms ease;white-space:nowrap;letter-spacing:.01em}
.cl-sl__tab:hover{border-color:rgba(77,209,176,.5);color:#4dd1b0;background:rgba(77,209,176,.07)}
.cl-sl__tab[aria-selected=true],.cl-sl__tab.is-active{background:#1d6e5a;border-color:#1d6e5a;color:#fff}
.cl-sl__tab-icon{font-size:15px}
.cl-sl__badge{font-size:10px;font-weight:800;letter-spacing:.08em;padding:2px 7px;border-radius:999px;background:rgba(255,200,50,.18);color:#ffc832;border:1px solid rgba(255,200,50,.3);margin-left:2px}
.cl-sl__badge--dev{background:rgba(255,255,255,.08);color:rgba(255,255,255,.6);border-color:rgba(255,255,255,.15)}
.cl-sl__panel{animation:cl-panel-in 280ms ease}
.cl-sl__panel[hidden]{display:none}
@keyframes cl-panel-in{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:none}}
.cl-sl__split{display:grid;grid-template-columns:420px 1fr;gap:clamp(24px,4vw,56px);align-items:center;margin-bottom:clamp(32px,5vw,56px);background:rgba(255,255,255,.03);border:1px solid rgba(77,209,176,.12);border-radius:16px;overflow:hidden}
.cl-sl__split-img{height:320px;overflow:hidden;background:rgba(0,0,0,.2)}
.cl-sl__split-img img{width:100%;height:100%;object-fit:cover;display:block;transition:transform 600ms ease}
.cl-sl__split:hover .cl-sl__split-img img{transform:scale(1.03)}
.cl-sl__split-img--placeholder{display:flex;align-items:center;justify-content:center}
.cl-sl__img-ph{text-align:center;color:rgba(255,255,255,.35)}
.cl-sl__img-ph span{font-size:48px;display:block;margin-bottom:8px}
.cl-sl__img-ph p{font-size:13px;margin:0}
.cl-sl__split-info{padding:clamp(24px,3vw,40px);padding-left:0}
.cl-sl__split-ew{color:#4dd1b0;font-size:11px;font-weight:800;letter-spacing:.14em;text-transform:uppercase;margin:0 0 10px}
.cl-sl__split-h3{font-size:clamp(28px,3.5vw,48px);font-weight:900;letter-spacing:-.02em;line-height:1.05;margin:0 0 14px;color:#fff}
.cl-sl__split-desc{color:rgba(255,255,255,.68);font-size:15px;line-height:1.65;margin:0 0 20px}
.cl-sl__split-desc strong{color:#ffc832}
.cl-sl__split-badge{display:inline-block;font-size:12px;font-weight:700;color:#ffc832;border:1px solid rgba(255,200,50,.35);border-radius:6px;padding:5px 12px;margin-bottom:18px}
.cl-sl__split-wa{display:inline-flex;align-items:center;gap:8px;background:#1d6e5a;color:#fff;text-decoration:none;font-size:14px;font-weight:700;padding:12px 20px;border-radius:8px;transition:background 180ms ease,transform 180ms ease}
.cl-sl__split-wa:hover{background:#24917a;color:#fff;transform:translateY(-2px)}
.cl-sl__subs-label{font-size:11px;font-weight:800;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.4);margin:0 0 14px}
.cl-sl__subs{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
.cl-sl__sub{background:rgba(255,255,255,.04);border:1px solid rgba(77,209,176,.15);border-radius:10px;overflow:hidden;transition:border-color 180ms ease}
.cl-sl__sub:hover,.cl-sl__sub[open]{border-color:rgba(77,209,176,.4)}
.cl-sl__sub--highlight{border-color:rgba(255,200,50,.35);background:rgba(255,200,50,.05)}
.cl-sl__sub--highlight:hover,.cl-sl__sub--highlight[open]{border-color:rgba(255,200,50,.65)}
.cl-sl__sub-sum{display:flex;align-items:center;justify-content:space-between;padding:14px 16px;cursor:pointer;list-style:none;gap:8px;user-select:none}
.cl-sl__sub-sum::-webkit-details-marker{display:none}
.cl-sl__sub-name{font-size:14px;font-weight:700;color:#fff;line-height:1.3;display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.cl-sl__sub-badge{font-size:10px;font-weight:800;letter-spacing:.06em;padding:2px 7px;border-radius:999px;background:rgba(255,200,50,.2);color:#ffc832;border:1px solid rgba(255,200,50,.4);text-transform:uppercase}
.cl-sl__chevron{width:18px;height:18px;flex-shrink:0;color:rgba(255,255,255,.4);transition:transform 250ms ease,color 180ms ease}
.cl-sl__sub[open] .cl-sl__chevron{transform:rotate(180deg);color:#4dd1b0}
.cl-sl__sub-body{padding:0 16px 16px;border-top:1px solid rgba(255,255,255,.07)}
.cl-sl__sub-body p{color:rgba(255,255,255,.68);font-size:14px;line-height:1.65;margin:12px 0 14px}
.cl-sl__sub-wa{display:inline-flex;align-items:center;gap:6px;background:rgba(37,211,102,.15);color:#25d366;border:1px solid rgba(37,211,102,.3);text-decoration:none;font-size:13px;font-weight:700;padding:9px 14px;border-radius:7px;transition:background 180ms ease,border-color 180ms ease}
.cl-sl__sub-wa::before{content:'💬';font-size:13px}
.cl-sl__sub-wa:hover{background:rgba(37,211,102,.25);border-color:rgba(37,211,102,.55);color:#25d366}
@media(max-width:900px){.cl-sl__split{grid-template-columns:1fr}.cl-sl__split-img{height:240px}.cl-sl__split-info{padding:24px;padding-top:0}}
@media(max-width:600px){.cl-sl__subs{grid-template-columns:1fr}.cl-sl__tab{padding:9px 14px;font-size:13px}}
</style>

<script>
(function(){
var section=document.getElementById('linhas-e-sublinhas');
if(!section)return;
var tabs=section.querySelectorAll('.cl-sl__tab');
var panels=section.querySelectorAll('.cl-sl__panel');
function activate(name){
  tabs.forEach(function(t){var a=t.dataset.tab===name;t.setAttribute('aria-selected',a?'true':'false');t.classList.toggle('is-active',a);});
  panels.forEach(function(p){if(p.dataset.panel===name){p.removeAttribute('hidden');}else{p.setAttribute('hidden','');}});
}
tabs.forEach(function(t){t.addEventListener('click',function(){activate(t.dataset.tab);history.replaceState(null,'','#linha-'+t.dataset.tab);});});
function handleHash(){var h=window.location.hash;if(!h)return;var name=h.replace('#linha-','');var ok=false;tabs.forEach(function(t){if(t.dataset.tab===name)ok=true;});if(ok){activate(name);section.scrollIntoView({behavior:'smooth',block:'start'});}}
handleHash();
window.addEventListener('hashchange',handleHash);
var anyActive=false;tabs.forEach(function(t){if(t.getAttribute('aria-selected')==='true')anyActive=true;});
if(!anyActive&&tabs.length)activate(tabs[0].dataset.tab);
})();
</script>

