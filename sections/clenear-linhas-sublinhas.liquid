{{ 'clenear-pages.css' | asset_url | stylesheet_tag }}

{%- assign wa_base = 'https://api.whatsapp.com/send?phone=552732280140&text=' -%}

<!-- Anchor bridge — cards section "Ver linha ↓" links point here -->
<span id="linha-domissanitaria"  style="display:block;height:0;visibility:hidden;" aria-hidden="true"></span>
<span id="linha-lavanderia"      style="display:block;height:0;visibility:hidden;" aria-hidden="true"></span>
<span id="linha-automotiva"      style="display:block;height:0;visibility:hidden;" aria-hidden="true"></span>
<span id="linha-industrial"      style="display:block;height:0;visibility:hidden;" aria-hidden="true"></span>
<span id="linha-construcao-civil" style="display:block;height:0;visibility:hidden;" aria-hidden="true"></span>
<span id="linha-insumos"         style="display:block;height:0;visibility:hidden;" aria-hidden="true"></span>

<section class="cl-sl" id="linhas-e-sublinhas" aria-label="Linhas e Sublinhas Clenear">
<div class="cl-sl__wrap">

  <!-- ── Header ── -->
  <div class="cl-sl__head">
    <p class="cl-sl__ew">Explore em detalhe</p>
    <h2 class="cl-sl__h2">Linhas &amp; Sublinhas</h2>
    <p class="cl-sl__lead">Você clicou em uma linha acima — ou selecione uma aba abaixo para descobrir as sublinhas de cada segmento e solicitar diretamente via WhatsApp.</p>
  </div>

  <!-- ── Search ── -->
  <div class="cl-sl__search-wrap">
    <svg class="cl-sl__search-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="8.5" cy="8.5" r="5.5"/><path d="M15 15l-3-3"/></svg>
    <input
      class="cl-sl__search"
      id="cl-sl-search"
      type="search"
      placeholder="Pesquisar linha, sublinha ou produto..."
      autocomplete="off"
      spellcheck="false"
    >
    <button class="cl-sl__search-clear" id="cl-sl-search-clear" aria-label="Limpar pesquisa" hidden>
      <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 6l8 8M14 6l-8 8"/></svg>
    </button>
    <div class="cl-sl__search-results" id="cl-sl-search-results" hidden role="listbox"></div>
  </div>

  <!-- ── Tab navigation ── -->
  <div class="cl-sl__tabs" role="tablist" aria-label="Selecionar linha">
    <button class="cl-sl__tab" role="tab" data-tab="domissanitaria" aria-selected="true"  aria-controls="panel-domissanitaria">
      <svg class="cl-sl__tab-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M7 20c0-3 2-5 5-5s5 2 5 5"/><path d="M9 9c0 0 1-4 3-4s3 4 3 4"/><path d="M8 9h8"/><path d="M9 9v3"/><path d="M15 9v3"/></svg>
      Domissanitária
    </button>
    <button class="cl-sl__tab" role="tab" data-tab="lavanderia"      aria-selected="false" aria-controls="panel-lavanderia">
      <svg class="cl-sl__tab-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3s6 7 6 11a6 6 0 0 1-12 0c0-4 6-11 6-11z"/></svg>
      Lavanderia
    </button>
    <button class="cl-sl__tab" role="tab" data-tab="automotiva"      aria-selected="false" aria-controls="panel-automotiva">
      <svg class="cl-sl__tab-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="9" width="20" height="8" rx="2"/><path d="M5 9l2-4h10l2 4"/><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/></svg>
      Automotiva
    </button>
    <button class="cl-sl__tab" role="tab" data-tab="industrial"      aria-selected="false" aria-controls="panel-industrial">
      <svg class="cl-sl__tab-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 010 14.14M4.93 4.93a10 10 0 000 14.14"/><path d="M15.54 8.46a5 5 0 010 7.07M8.46 8.46a5 5 0 000 7.07"/></svg>
      Industrial
    </button>
    <button class="cl-sl__tab" role="tab" data-tab="construcao-civil" aria-selected="false" aria-controls="panel-construcao-civil">
      <svg class="cl-sl__tab-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="8" y="3" width="8" height="8"/></svg>
      Construção Civil
    </button>
    <button class="cl-sl__tab" role="tab" data-tab="insumos"         aria-selected="false" aria-controls="panel-insumos">
      <svg class="cl-sl__tab-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6"/><path d="M10 3v6l-5 8.5A2 2 0 0 0 7 21h10a2 2 0 0 0 1.8-3.5L14 9V3"/></svg>
      Insumos e Revenda
    </button>
  </div>

