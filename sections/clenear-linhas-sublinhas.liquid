<script>
(function(){
  var section=document.getElementById('linhas-e-sublinhas');
  if(!section)return;
  var tabs=section.querySelectorAll('.cl-sl__tab');
  var panels=section.querySelectorAll('.cl-sl__panel');
  function activateTab(name){
    tabs.forEach(function(t){var a=t.dataset.tab===name;t.setAttribute('aria-selected',a?'true':'false');t.classList.toggle('is-active',a);});
    panels.forEach(function(p){p.dataset.panel===name?p.removeAttribute('hidden'):p.setAttribute('hidden','');});
    var panel=section.querySelector('[data-panel="'+name+'"]');
    if(panel) initMD(panel);
  }
  tabs.forEach(function(t){t.addEventListener('click',function(){activateTab(t.dataset.tab);history.replaceState(null,'','#linha-'+t.dataset.tab);});});
  function initMD(panel){
    var items=panel.querySelectorAll('.cl-sl__md-item');
    var contents=panel.querySelectorAll('.cl-sl__md-content');
    var hasActive=false;
    items.forEach(function(i){if(i.classList.contains('is-active'))hasActive=true;});
    if(!hasActive && items.length){items[0].classList.add('is-active');var idx=items[0].dataset.idx;var c=panel.querySelector('.cl-sl__md-content[data-idx="'+idx+'"]');if(c) c.classList.add('is-active');}
    items.forEach(function(item){
      item.addEventListener('click',function(){
        items.forEach(function(i){i.classList.remove('is-active');});
        contents.forEach(function(c){c.classList.remove('is-active');});
        item.classList.add('is-active');
        var c=panel.querySelector('.cl-sl__md-content[data-idx="'+item.dataset.idx+'"]');
        if(c) c.classList.add('is-active');
      });
    });
  }
  panels.forEach(function(p){initMD(p);});
  function handleHash(){
    var h=window.location.hash;
    if(!h)return;
    var name=h.replace('#linha-','');
    var matched=false;
    tabs.forEach(function(t){if(t.dataset.tab===name)matched=true;});
    if(matched){activateTab(name);setTimeout(function(){section.scrollIntoView({behavior:'smooth',block:'start'});},50);}
  }
  handleHash();
  window.addEventListener('hashchange',handleHash);
  var anyActive=false;
  tabs.forEach(function(t){if(t.getAttribute('aria-selected')==='true'||t.classList.contains('is-active'))anyActive=true;});
  if(!anyActive && tabs.length) activateTab(tabs[0].dataset.tab);
  var index=[];
  panels.forEach(function(panel){
    var line=panel.dataset.panel;
    var lineLabel=panel.querySelector('.cl-sl__line-h3');
    lineLabel=lineLabel?lineLabel.textContent.trim():'';
    panel.querySelectorAll('.cl-sl__md-item').forEach(function(item){
      var name=item.querySelector('.cl-sl__md-name');
      name=name?name.textContent.trim():'';
      var content=panel.querySelector('.cl-sl__md-content[data-idx="'+item.dataset.idx+'"]');
      var products='';
      if(content){
        var prodEls=content.querySelectorAll('.cl-sl__md-products li');
        prodEls.forEach(function(p){products+=' '+p.textContent.trim();});
      }
      var search=(item.dataset.search||'')+' '+name+' '+products;
      index.push({line:line,lineLabel:lineLabel,name:name,idx:item.dataset.idx,search:search.toLowerCase()});
    });
  });
  var inp=document.getElementById('cl-sl-search');
  var res=document.getElementById('cl-sl-search-results');
  var clr=document.getElementById('cl-sl-search-clear');
  if(!inp||!res)return;
  function renderResults(matches){
    res.removeAttribute('hidden');
    if(!matches.length){res.innerHTML='<p class="cl-sl__sr-empty">Nenhum resultado encontrado.</p>';return;}
    res.innerHTML=matches.map(function(s){return '<div class="cl-sl__sr-item" role="option" data-line="'+s.line+'" data-idx="'+s.idx+'"><span class="cl-sl__sr-line">'+s.lineLabel+'</span><span class="cl-sl__sr-name">'+s.name+'</span></div>';}).join('');
    res.querySelectorAll('.cl-sl__sr-item').forEach(function(el){
      el.addEventListener('click',function(){
        var l=el.dataset.line,i=el.dataset.idx;
        activateTab(l);
        var panel=section.querySelector('[data-panel="'+l+'"]');
        if(panel){var target=panel.querySelector('.cl-sl__md-item[data-idx="'+i+'"]');if(target) target.click();}
        inp.value='';res.setAttribute('hidden','');clr.setAttribute('hidden','');
        section.scrollIntoView({behavior:'smooth',block:'start'});
      });
    });
  }
  inp.addEventListener('input',function(){var q=this.value.trim().toLowerCase();clr.toggleAttribute('hidden',!q);if(!q){res.setAttribute('hidden','');return;}var m=index.filter(function(s){return s.search.includes(q)||s.lineLabel.toLowerCase().includes(q);});renderResults(m);});
  clr.addEventListener('click',function(){inp.value='';inp.focus();res.setAttribute('hidden','');clr.setAttribute('hidden','');});
  document.addEventListener('click',function(e){if(!inp.contains(e.target)&&!res.contains(e.target)){res.setAttribute('hidden','');}});
})();
</script>

