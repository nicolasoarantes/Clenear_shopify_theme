.cl-sl__sub-label{font-size:11px;font-weight:800;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.38);margin:0 0 14px}
.cl-sl__sub-label span{font-weight:500;letter-spacing:0;text-transform:none;opacity:.7}
.cl-sl__md{display:grid;grid-template-columns:300px 1fr;border:1px solid rgba(77,209,176,.12);border-radius:16px;overflow:hidden;min-height:340px}
.cl-sl__md-list{list-style:none;padding:10px;margin:0;display:flex;flex-direction:column;gap:3px;border-right:1px solid rgba(77,209,176,.1);background:rgba(0,0,0,.18);overflow-y:auto;max-height:480px}
.cl-sl__md-list::-webkit-scrollbar{width:4px}
.cl-sl__md-list::-webkit-scrollbar-thumb{background:rgba(77,209,176,.25);border-radius:4px}
.cl-sl__md-item{display:flex;align-items:center;gap:12px;padding:12px 14px;border-radius:8px;cursor:pointer;transition:background 140ms,color 140ms;color:rgba(255,255,255,.58);font-size:14px;font-weight:600;line-height:1.3;user-select:none}
.cl-sl__md-item:hover:not(.is-active){background:rgba(255,255,255,.05);color:rgba(255,255,255,.82)}
.cl-sl__md-item.is-active{background:rgba(77,209,176,.14);color:#fff;border:1px solid rgba(77,209,176,.25)}
.cl-sl__md-item.is-active .cl-sl__md-arr{opacity:1;color:#4dd1b0;transform:translateX(2px)}
.cl-sl__md-item--star.is-active{background:rgba(255,200,50,.12);border-color:rgba(255,200,50,.3)}
.cl-sl__md-item--star .cl-sl__md-num{color:#ffc832}
.cl-sl__md-num{font-size:11px;font-weight:800;color:#4dd1b0;min-width:22px;letter-spacing:.04em;flex-shrink:0}
.cl-sl__md-name{flex:1;display:flex;align-items:center;flex-wrap:wrap;gap:6px}
.cl-sl__md-chip{font-size:9px;font-weight:800;letter-spacing:.08em;text-transform:uppercase;padding:2px 7px;border-radius:999px;background:rgba(255,200,50,.2);color:#ffc832;border:1px solid rgba(255,200,50,.35)}
.cl-sl__md-arr{width:14px;height:14px;flex-shrink:0;opacity:.25;transition:opacity 140ms,transform 140ms}
.cl-sl__md-detail{padding:clamp(24px,3vw,40px);position:relative;background:rgba(255,255,255,.015)}
.cl-sl__md-content{display:none}
.cl-sl__md-content.is-active{display:flex;flex-direction:column;animation:cl-fade-up 200ms ease}
@keyframes cl-fade-up{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
.cl-sl__md-h4{font-size:clamp(22px,2.8vw,34px);font-weight:900;color:#fff;margin:0 0 16px;letter-spacing:-.02em;line-height:1.08}
.cl-sl__md-desc{color:rgba(255,255,255,.68);font-size:16px;line-height:1.7;margin:0 0 28px;flex:1}
