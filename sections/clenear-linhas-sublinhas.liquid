        <li class="cl-sl__md-item" role="option" data-idx="5" data-search="Aromatizantes Stigma ambiente odor perfume"><span class="cl-sl__md-num">06</span><span class="cl-sl__md-name">Aromatizantes — Clenear &amp; Stigma</span><svg class="cl-sl__md-arr" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 3l5 5-5 5"/></svg></li>
