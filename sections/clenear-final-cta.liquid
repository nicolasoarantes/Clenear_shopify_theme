<section class="cl-final-cta cl-dark" id="contato"><div class="cl-final-cta__bg" aria-hidden="true"></div><div class="cl-wrap cl-final-cta__inner">
  {%- if section.settings.eyebrow != blank -%}<p class="cl-label" style="justify-content:center;">{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
  <h2 class="cl-h2">{{ section.settings.heading }}</h2>
  <p class="cl-lead">{{ section.settings.subtext }}</p>
  <div class="cl-btn-row">{%- if section.settings.cta_wa_label != blank -%}<a href="{{ section.settings.cta_wa_url }}" class="cl-btn cl-btn--whatsapp" target="_blank" rel="noopener">{{ section.settings.cta_wa_label | escape }}</a>{%- endif -%}{%- if section.settings.cta2_label != blank -%}<a href="{{ section.settings.cta2_url }}" class="cl-btn cl-btn--white" {% if section.settings.cta2_url contains 'http' %}target="_blank" rel="noopener"{% endif %}>{{ section.settings.cta2_label | escape }}</a>{%- endif -%}{%- if section.settings.cta3_label != blank -%}<a href="{{ section.settings.cta3_url }}" class="cl-btn cl-btn--ghost" {% if section.settings.cta3_url contains 'http' %}target="_blank" rel="noopener"{% endif %}>{{ section.settings.cta3_label | escape }}</a>{%- endif -%}</div>
  <div class="cl-final-cta__channels">{%- if section.settings.phone != blank -%}<div class="cl-final-cta__channel"><span>Telefone</span><a href="tel:{{ section.settings.phone | remove: ' ' | remove: '(' | remove: ')' | remove: '-' }}">{{ section.settings.phone }}</a></div>{%- endif -%}{%- if section.settings.email != blank -%}<div class="cl-final-cta__channel"><span>E-mail</span><a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a></div>{%- endif -%}{%- if section.settings.city != blank -%}<div class="cl-final-cta__channel"><span>Localização</span><a href="#">{{ section.settings.city }}</a></div>{%- endif -%}</div>
</div></section>
{% schema %}{"name":"Clenear: CTA Final","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Pronto para começar?"},{"type":"text","id":"heading","label":"Título","default":"Fale com a equipe Clenear"},{"type":"textarea","id":"subtext","label":"Subtexto","default":"Precisa de orçamento, quer revender ou tem dúvida técnica?"},{"type":"text","id":"cta_wa_label","label":"WhatsApp","default":"Chamar no WhatsApp"},{"type":"url","id":"cta_wa_url","label":"WhatsApp link"},{"type":"text","id":"cta2_label","label":"CTA 2","default":"Solicitar orçamento"},{"type":"url","id":"cta2_url","label":"CTA 2 link"},{"type":"text","id":"cta3_label","label":"CTA 3","default":"Quero revender"},{"type":"url","id":"cta3_url","label":"CTA 3 link"},{"type":"text","id":"phone","label":"Telefone","default":"(27) 3228-0140"},{"type":"text","id":"email","label":"E-mail"},{"type":"text","id":"city","label":"Cidade","default":"Serra — Espírito Santo"}],"presets":[{"name":"Clenear CTA Final"}]}{% endschema %}
