{{ 'clenear-pages.css' | asset_url | stylesheet_tag }}
{{ 'clenear-home-v2.css' | asset_url | stylesheet_tag }}

{%- comment -%} ===== CURSOR GLOW (non-hero sections) ===== {%- endcomment -%}
<div class="cl-pi-cursor-glow" id="cl-pi-cursor" aria-hidden="true"></div>

<div class="cl-pg-page" id="pesquisa-inovacao">

  {%- comment -%} ===== HERO - THREE.JS ===== {%- endcomment -%}
  <section class="cl-pi-hero" id="cl-pi-hero-section">
    <canvas class="cl-pi-hero__canvas" id="cl-pi-canvas" aria-hidden="true"></canvas>
    <div class="cl-pi-hero__overlay" aria-hidden="true"></div>
    <div class="cl-pg-wrap cl-pi-hero__wrap">
      <div class="cl-pi-hero__content cl-pg-fade">
        <div class="cl-pi-hero__badge">
          <span class="cl-pi-hero__badge-dot"></span>
          Laboratorio proprio · Serra, ES
        </div>
        <p class="cl-pg-eyebrow" style="text-align:center;">Pesquisa &amp; Inovacao</p>
        <h1 class="cl-pg-h1" style="text-align:center;margin-bottom:2.4rem;max-width:84rem;margin-left:auto;margin-right:auto;">
          Ciencia e tecnica no <em>desenvolvimento de cada formula</em>
        </h1>
        <p class="cl-pg-lead" style="text-align:center;max-width:66rem;margin-left:auto;margin-right:auto;margin-bottom:4rem;">
          Cada produto Clenear nasce de um processo rigoroso de pesquisa, teste e validacao. Investimos em P&amp;D para entregar formulacoes que se destacam em desempenho, seguranca e sustentabilidade.
        </p>
        <div class="cl-pg-btn-row" style="justify-content:center;">
          <a href="https://api.whatsapp.com/send?phone=552732280140&text=Ol%C3%A1!%20Vim%20pelo%20site%20da%20Clenear%20e%20gostaria%20de%20falar%20com%20o%20Setor%20T%C3%A9cnico."
             class="cl-pg-btn cl-pg-btn--wa" target="_blank" rel="noopener">
            Falar com o Setor Tecnico
          </a>
          <a href="/pages/nossas-linhas" class="cl-pg-btn cl-pg-btn--outline">
            Conheca Nossas Linhas
          </a>
        </div>
      </div>
    </div>
    <div class="cl-pi-hero__scroll-hint" aria-hidden="true"><span></span></div>
  </section>

  {%- comment -%} ===== PILARES ===== {%- endcomment -%}
  <section class="cl-pg-section cl-pg-section--alt cl-pi-section" data-cursor-section>
    <div class="cl-pg-wrap">
      <div class="cl-pg-intro cl-pg-intro--center cl-pg-fade">
        <p class="cl-pg-eyebrow">{{ section.settings.pilares_eyebrow | default: 'Nossos pilares' }}</p>
        <h2 class="cl-pg-h2">{{ section.settings.pilares_title | default: 'Como desenvolvemos <em>cada produto</em>' }}</h2>
        <p class="cl-pg-lead cl-pg-lead--wide">{{ section.settings.pilares_subtitle | default: 'Quatro pilares guiam o nosso processo de pesquisa e desenvolvimento desde a concepcao ate o produto final.' }}</p>
      </div>
      <div class="cl-pg-cards cl-pg-cards--4 cl-pg-fade cl-pg-fade--d1 cl-pi-desktop-cards">
        {%- for block in section.blocks -%}
          {%- if block.type == 'pilar' -%}
            <div class="cl-pg-card cl-pi-card" {{ block.shopify_attributes }}>
              <div class="cl-pg-card__number">{{ block.settings.number | default: '01' }}</div>
              <div class="cl-pi-card__icon-wrap"><span class="cl-pg-card__icon" aria-hidden="true">{{ block.settings.icon }}</span></div>
              <h3 class="cl-pg-card__title">{{ block.settings.title }}</h3>
              <p class="cl-pg-card__text">{{ block.settings.text }}</p>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
      <div class="cl-pi-carousel cl-pg-fade cl-pg-fade--d1">
        <div class="cl-pi-carousel__track" id="cl-pilares-track">
          {%- for block in section.blocks -%}
            {%- if block.type == 'pilar' -%}
              <div class="cl-pg-card cl-pi-card cl-pi-carousel__item" {{ block.shopify_attributes }}>
                <div class="cl-pg-card__number">{{ block.settings.number | default: '01' }}</div>
                <div class="cl-pi-card__icon-wrap"><span class="cl-pg-card__icon" aria-hidden="true">{{ block.settings.icon }}</span></div>
                <h3 class="cl-pg-card__title">{{ block.settings.title }}</h3>
                <p class="cl-pg-card__text">{{ block.settings.text }}</p>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
        <div class="cl-pi-carousel__dots" id="cl-pilares-dots" aria-hidden="true"></div>
      </div>
    </div>
  </section>

  {%- comment -%} ===== STATS ===== {%- endcomment -%}
  <section class="cl-pg-section cl-pg-section--dark cl-pi-stats-section" data-cursor-section>
    <div class="cl-pg-wrap">
      <div class="cl-pi-stats cl-pg-fade">
        <div class="cl-pi-stat"><span class="cl-pi-stat__value">+18</span><span class="cl-pi-stat__label">anos de experiencia</span></div>
        <div class="cl-pi-stat__divider" aria-hidden="true"></div>
        <div class="cl-pi-stat"><span class="cl-pi-stat__value">+50</span><span class="cl-pi-stat__label">formulacoes desenvolvidas</span></div>
        <div class="cl-pi-stat__divider" aria-hidden="true"></div>
        <div class="cl-pi-stat"><span class="cl-pi-stat__value">100%</span><span class="cl-pi-stat__label">desenvolvimento interno</span></div>
        <div class="cl-pi-stat__divider" aria-hidden="true"></div>
        <div class="cl-pi-stat"><span class="cl-pi-stat__value">Lab</span><span class="cl-pi-stat__label">proprio em Serra, ES</span></div>
      </div>
    </div>
  </section>

  {%- comment -%} ===== PROCESSO ===== {%- endcomment -%}
  <section class="cl-pg-section cl-pg-section--alt cl-pi-section" data-cursor-section>
    <div class="cl-pg-wrap">
      <div class="cl-pg-split">
        <div class="cl-pg-fade">
          <p class="cl-pg-eyebrow">{{ section.settings.proc_eyebrow | default: 'Da ideia ao produto' }}</p>
          <h2 class="cl-pg-h2">{{ section.settings.proc_title | default: 'Um processo <em>rigoroso</em> de desenvolvimento' }}</h2>
          <p class="cl-pg-lead">{{ section.settings.proc_text | default: 'Nenhum produto chega ao mercado sem passar por fases estruturadas de pesquisa, formulacao, testes de campo e validacao de seguranca.' }}</p>
          <ul class="cl-pg-split__list cl-pi-steps">
            {%- assign step_num = 1 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'processo_item' -%}
                <li class="cl-pi-step" {{ block.shopify_attributes }}>
                  <span class="cl-pi-step__num">0{{ step_num }}</span>
                  <span class="cl-pi-step__text">{{ block.settings.text }}</span>
                </li>
                {%- assign step_num = step_num | plus: 1 -%}
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </div>
        <div class="cl-pg-split__media cl-pg-fade cl-pg-fade--d2">
          {%- if section.settings.proc_image != blank -%}
            {{ section.settings.proc_image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '400, 700, 800', sizes: '(min-width: 1024px) 44vw, 90vw', alt: 'Processo de P&D Clenear' }}
          {%- else -%}
            <div class="cl-pg-placeholder cl-pi-placeholder-glow">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2v-4M9 21H5a2 2 0 0 1-2-2v-4m0 0h18"/></svg>
              <span>Foto laboratorio / processo (16:9)</span>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ===== PARCERIA TECNICA ===== {%- endcomment -%}
  <section class="cl-pg-section cl-pg-section--dark cl-pi-section" data-cursor-section>
    <div class="cl-pg-wrap">
      <div class="cl-pg-split cl-pg-split--flip">
        <div class="cl-pg-split__media cl-pg-fade">
          {%- if section.settings.parceria_image != blank -%}
            {{ section.settings.parceria_image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '400, 700, 800', sizes: '(min-width: 1024px) 44vw, 90vw', alt: 'Parceria tecnica Clenear' }}
          {%- else -%}
            <div class="cl-pg-placeholder cl-pi-placeholder-glow">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              <span>Foto reuniao / parceria (16:9)</span>
            </div>
          {%- endif -%}
        </div>
        <div class="cl-pg-fade cl-pg-fade--d1">
          <p class="cl-pg-eyebrow">{{ section.settings.parceria_eyebrow | default: 'Desenvolvimento colaborativo' }}</p>
          <h2 class="cl-pg-h2">{{ section.settings.parceria_title | default: 'Formulamos sob medida <em>para o seu negocio</em>' }}</h2>
          <p class="cl-pg-lead">{{ section.settings.parceria_text | default: 'Seja para criar uma nova linha, adaptar uma formulacao ou desenvolver um produto exclusivo, nosso time tecnico trabalha ao seu lado em cada etapa.' }}</p>
          <ul class="cl-pg-split__list">
            {%- for block in section.blocks -%}
              {%- if block.type == 'parceria_item' -%}
                <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
          <div class="cl-pg-btn-row">
            <a href="https://api.whatsapp.com/send?phone=552732280140&text=Ol%C3%A1!%20Vim%20pelo%20site%20da%20Clenear%20e%20gostaria%20de%20falar%20com%20o%20Setor%20T%C3%A9cnico%20sobre%20desenvolvimento%20de%20f%C3%B3rmula."
               class="cl-pg-btn cl-pg-btn--wa" target="_blank" rel="noopener">
              Falar com o Setor Tecnico
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ===== MID CTA ===== {%- endcomment -%}
  <section class="cl-pg-section cl-pg-section--alt cl-pi-section" data-cursor-section>
    <div class="cl-pg-wrap">
      <div class="cl-pg-mid-cta cl-pg-fade">
        <p class="cl-pg-eyebrow" style="text-align:center;">{{ section.settings.mid_cta_eyebrow | default: 'Vamos conversar?' }}</p>
        <h3>{{ section.settings.mid_cta_heading | default: 'Tem uma necessidade tecnica especifica?' }}</h3>
        <p>{{ section.settings.mid_cta_text | default: 'Nossa equipe de P&D esta pronta para desenvolver a formulacao ideal para o seu segmento e aplicacao.' }}</p>
        <div class="cl-pg-btn-row">
          <a href="https://api.whatsapp.com/send?phone=552732280140&text=Ol%C3%A1!%20Vim%20pelo%20site%20da%20Clenear%20e%20gostaria%20de%20falar%20com%20o%20Setor%20T%C3%A9cnico."
             class="cl-pg-btn cl-pg-btn--wa" target="_blank" rel="noopener">
            Falar com o Setor Tecnico
          </a>
          <a href="/pages/nossas-linhas" class="cl-pg-btn cl-pg-btn--outline">
            Conheca Nossas Linhas
          </a>
        </div>
      </div>
    </div>
  </section>

</div>

<style>
.cl-pi-hero {
  position: relative;
  min-height: 90vh;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: #0A1812;
}
.cl-pi-hero__canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  display: block;
}
.cl-pi-hero__overlay {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 80% 60% at 50% 40%, rgba(29,110,90,0.13) 0%, transparent 70%),
    radial-gradient(ellipse 60% 40% at 20% 80%, rgba(29,110,90,0.07) 0%, transparent 60%);
  pointer-events: none;
}
.cl-pi-hero__wrap {
  position: relative;
  z-index: 2;
  width: 100%;
  padding-top: 10rem;
  padding-bottom: 10rem;
}
.cl-pi-hero__content { text-align: center; }
.cl-pi-hero__badge {
  display: inline-flex;
  align-items: center;
  gap: 0.8rem;
  background: rgba(29,110,90,0.15);
  border: 1px solid rgba(29,110,90,0.35);
  border-radius: 10rem;
  color: rgba(255,255,255,0.75);
  font-size: 1.25rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  margin-bottom: 2.4rem;
  padding: 0.7rem 1.8rem;
  text-transform: uppercase;
}
.cl-pi-hero__badge-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #1D6E5A;
  box-shadow: 0 0 6px #1D6E5A;
  animation: cl-pi-pulse 2s ease-in-out infinite;
}
@keyframes cl-pi-pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.4; transform: scale(0.7); }
}
.cl-pi-hero__scroll-hint {
  position: absolute;
  bottom: 3.2rem;
  left: 50%;
  transform: translateX(-50%);
  z-index: 2;
}
.cl-pi-hero__scroll-hint span {
  display: block;
  width: 22px;
  height: 22px;
  border-right: 2px solid rgba(255,255,255,0.3);
  border-bottom: 2px solid rgba(255,255,255,0.3);
  transform: rotate(45deg);
  animation: cl-pi-scroll-hint 1.6s ease-in-out infinite;
}
@keyframes cl-pi-scroll-hint {
  0% { opacity: 0; transform: rotate(45deg) translate(-4px,-4px); }
  50% { opacity: 1; }
  100% { opacity: 0; transform: rotate(45deg) translate(4px,4px); }
}
.cl-pi-cursor-glow {
  position: fixed;
  top: 0;
  left: 0;
  width: 400px;
  height: 400px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(29,110,90,0.06) 0%, transparent 70%);
  pointer-events: none;
  z-index: 9999;
  opacity: 0;
  will-change: transform;
}
.cl-pi-card {
  transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
}
.cl-pi-card:hover {
  transform: translateY(-4px);
  border-color: rgba(29,110,90,0.4) !important;
  box-shadow: 0 16px 40px rgba(0,0,0,0.3), 0 0 0 1px rgba(29,110,90,0.15);
}
.cl-pi-card__icon-wrap { margin-bottom: 1.2rem; }
.cl-pi-stats-section { padding: 6rem 0 !important; }
.cl-pi-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
}
.cl-pi-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  padding: 2.4rem 4.8rem;
  text-align: center;
}
.cl-pi-stat__value {
  font-size: 3.8rem;
  font-weight: 800;
  letter-spacing: -0.02em;
  line-height: 1;
  background: linear-gradient(135deg, #fff 0%, rgba(29,110,90,0.9) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.cl-pi-stat__label {
  color: rgba(255,255,255,0.5);
  font-size: 1.3rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}
.cl-pi-stat__divider {
  width: 1px;
  height: 4rem;
  background: rgba(255,255,255,0.1);
  flex-shrink: 0;
}
.cl-pi-steps {
  list-style: none;
  padding: 0;
  margin: 2.4rem 0 3.2rem;
  display: flex;
  flex-direction: column;
  gap: 1.2rem;
}
.cl-pi-step {
  display: flex;
  align-items: flex-start;
  gap: 1.4rem;
  padding: 1.4rem 1.8rem;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 1rem;
  transition: border-color 0.2s ease, background 0.2s ease;
}
.cl-pi-step:hover {
  background: rgba(29,110,90,0.06);
  border-color: rgba(29,110,90,0.25);
}
.cl-pi-step__num {
  color: #1D6E5A;
  font-size: 1.15rem;
  font-weight: 800;
  letter-spacing: 0.05em;
  min-width: 2.4rem;
  padding-top: 0.15rem;
}
.cl-pi-step__text {
  color: rgba(255,255,255,0.75);
  font-size: 1.5rem;
  line-height: 1.5;
}
.cl-pi-placeholder-glow {
  background: rgba(29,110,90,0.04) !important;
  border-color: rgba(29,110,90,0.15) !important;
}
.cl-pi-desktop-cards { display: grid; }
.cl-pi-carousel { display: none; }
.cl-pi-carousel__track {
  display: flex;
  gap: 1.6rem;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  padding-bottom: 1.2rem;
}
.cl-pi-carousel__track::-webkit-scrollbar { display: none; }
.cl-pi-carousel__item {
  flex: 0 0 85vw;
  scroll-snap-align: start;
  max-width: 34rem;
}
.cl-pi-carousel__dots {
  display: flex;
  justify-content: center;
  gap: 0.7rem;
  margin-top: 2rem;
}
.cl-pi-carousel__dots span {
  display: block;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: rgba(255,255,255,0.18);
  transition: background 0.2s ease, transform 0.2s ease;
  cursor: pointer;
}
.cl-pi-carousel__dots span.is-active {
  background: #1D6E5A;
  transform: scale(1.3);
}
@media (max-width: 767px) {
  .cl-pi-desktop-cards { display: none !important; }
  .cl-pi-carousel { display: block; }
  .cl-pi-stat { padding: 1.8rem 2.4rem; }
  .cl-pi-stat__value { font-size: 2.8rem; }
  .cl-pi-stat__divider { display: none; }
}
</style>

<script>
/* Three.js particle hero */
(function () {
  var canvas = document.getElementById('cl-pi-canvas');
  if (!canvas) return;
  var THREE, scene, camera, renderer, particles, positions, velocities;
  var mouse = { x: 0, y: 0 };
  var PARTICLE_COUNT = 120;
  var active = false, animFrame, initialized = false;

  function init(T) {
    THREE = T; initialized = true;
    scene = new THREE.Scene();
    var w = canvas.clientWidth || window.innerWidth;
    var h = canvas.clientHeight || window.innerHeight;
    camera = new THREE.PerspectiveCamera(60, w / h, 0.1, 1000);
    camera.position.z = 80;
    renderer = new THREE.WebGLRenderer({ canvas: canvas, alpha: true, antialias: false });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5));
    renderer.setSize(w, h);
    renderer.setClearColor(0x000000, 0);
    var geo = new THREE.BufferGeometry();
    var pos = new Float32Array(PARTICLE_COUNT * 3);
    var col = new Float32Array(PARTICLE_COUNT * 3);
    positions = []; velocities = [];
    for (var i = 0; i < PARTICLE_COUNT; i++) {
      var x = (Math.random() - 0.5) * 140;
      var y = (Math.random() - 0.5) * 80;
      var z = (Math.random() - 0.5) * 40;
      pos[i*3]=x; pos[i*3+1]=y; pos[i*3+2]=z;
      positions.push({ x:x, y:y, z:z, ox:x, oy:y });
      velocities.push({ phase: Math.random() * Math.PI * 2 });
      if (Math.random() > 0.35) { col[i*3]=0.114; col[i*3+1]=0.431; col[i*3+2]=0.353; }
      else { col[i*3]=1; col[i*3+1]=1; col[i*3+2]=1; }
    }
    geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
    geo.setAttribute('color', new THREE.BufferAttribute(col, 3));
    var mat = new THREE.PointsMaterial({ size:0.55, vertexColors:true, transparent:true, opacity:0.45, sizeAttenuation:true });
    particles = new THREE.Points(geo, mat);
    scene.add(particles);
    window.addEventListener('resize', function() {
      var w=canvas.clientWidth, h=canvas.clientHeight;
      if(!w||!h) return;
      camera.aspect=w/h; camera.updateProjectionMatrix(); renderer.setSize(w,h);
    });
    document.addEventListener('mousemove', function(e) {
      var r = canvas.getBoundingClientRect();
      mouse.x = ((e.clientX-r.left)/r.width - 0.5)*140;
      mouse.y = -((e.clientY-r.top)/r.height - 0.5)*80;
    });
    active = true; animate(0);
  }

  function animate(t) {
    if (!active) return;
    animFrame = requestAnimationFrame(animate);
    var pos = particles.geometry.attributes.position.array;
    var REPEL = 150*150;
    for (var i=0; i<PARTICLE_COUNT; i++) {
      var vel=velocities[i], p=positions[i];
      p.x = p.ox + Math.sin(t*0.0004+vel.phase)*2.5;
      p.y = p.oy + Math.cos(t*0.0003+vel.phase)*1.8;
      var dx=p.x-mouse.x*0.8, dy=p.y-mouse.y*0.8, dist2=dx*dx+dy*dy;
      if (dist2<REPEL && dist2>0.01) {
        var force=(1-dist2/REPEL)*0.18, d=Math.sqrt(dist2);
        p.x+=(dx/d)*force; p.y+=(dy/d)*force;
      }
      pos[i*3]=p.x; pos[i*3+1]=p.y; pos[i*3+2]=p.z;
    }
    particles.geometry.attributes.position.needsUpdate=true;
    renderer.render(scene,camera);
  }

  var heroSection = document.getElementById('cl-pi-hero-section');
  if ('IntersectionObserver' in window && heroSection) {
    new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) { if (!active && initialized) { active=true; animate(performance.now()); } }
        else { active=false; if(animFrame) cancelAnimationFrame(animFrame); }
      });
    }, { threshold:0 }).observe(heroSection);
  }

  var s = document.createElement('script');
  s.src = 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';
  s.crossOrigin = 'anonymous';
  s.onload = function() { init(window.THREE); };
  s.onerror = function() { if(canvas) canvas.style.display='none'; };
  document.head.appendChild(s);
})();

/* Cursor glow */
(function () {
  var glow = document.getElementById('cl-pi-cursor');
  if (!glow || window.matchMedia('(pointer: coarse)').matches) return;
  var tx=-999, ty=-999, cx=-999, cy=-999;
  document.addEventListener('mousemove', function(e) {
    tx=e.clientX; ty=e.clientY;
    var el = document.elementFromPoint(e.clientX, e.clientY);
    glow.style.opacity = (el && el.closest('[data-cursor-section]')) ? '1' : '0';
  });
  function lerp(a,b,t) { return a+(b-a)*t; }
  (function tick() {
    cx=lerp(cx,tx,0.08); cy=lerp(cy,ty,0.08);
    glow.style.transform='translate('+(cx-200)+'px,'+(cy-200)+'px)';
    requestAnimationFrame(tick);
  })();
})();

/* Scroll fade-in */
(function () {
  var fades = document.querySelectorAll('#pesquisa-inovacao .cl-pg-fade');
  if ('IntersectionObserver' in window) {
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) { if(e.isIntersecting){e.target.classList.add('is-visible');io.unobserve(e.target);} });
    }, { threshold:0.08 });
    fades.forEach(function(el) { io.observe(el); });
  } else { fades.forEach(function(el){el.classList.add('is-visible');}); }
})();

/* Mobile carousel dots */
(function () {
  var track = document.getElementById('cl-pilares-track');
  var dotsWrap = document.getElementById('cl-pilares-dots');
  if (!track || !dotsWrap) return;
  var items = track.querySelectorAll('.cl-pi-carousel__item');
  if (!items.length) return;
  var dots = [];
  items.forEach(function(item, i) {
    var dot = document.createElement('span');
    dot.addEventListener('click', function() {
      track.scrollTo({ left: item.offsetLeft - track.offsetLeft, behavior: 'smooth' });
    });
    dotsWrap.appendChild(dot);
    dots.push(dot);
  });
  if (dots.length) dots[0].classList.add('is-active');
  track.addEventListener('scroll', function() {
    var w = items[0].getBoundingClientRect().width;
    var idx = Math.max(0, Math.min(Math.round(track.scrollLeft/(w+16)), dots.length-1));
    dots.forEach(function(d,i){d.classList.toggle('is-active', i===idx);});
  }, { passive:true });
})();
</script>

