{{ 'clenear-pages.css' | asset_url | stylesheet_tag }}
{{ 'clenear-home-v2.css' | asset_url | stylesheet_tag }}
{{ 'clenear-pi.css' | asset_url | stylesheet_tag }}

{%- comment -%} ===== CURSOR GLOW (non-hero sections) ===== {%- endcomment -%}
<div class="cl-pi-cursor-glow" id="cl-pi-cursor" aria-hidden="true"></div>

<div class="cl-pg-page" id="pesquisa-inovacao">

  {%- comment -%} ===== HERO - THREE.JS ===== {%- endcomment -%}
  <section class="cl-pi-hero" id="cl-pi-hero-section">
    <canvas class="cl-pi-hero__canvas" id="cl-pi-canvas" aria-hidden="true"></canvas>
    <div class="cl-pi-hero__overlay" aria-hidden="true"></div>
    <div class="cl-pg-wrap cl-pi-hero__wrap">
      <div class="cl-pi-hero__content cl-pg-fade">
        <div class="cl-pi-hero__badge">
          <span class="cl-pi-hero__badge-dot"></span>
          Laboratorio proprio &middot; Serra, ES
        </div>
        <p class="cl-pg-eyebrow" style="text-align:center;">Pesquisa &amp; Inovacao</p>
        <h1 class="cl-pg-h1" style="text-align:center;margin-bottom:2.4rem;max-width:84rem;margin-left:auto;margin-right:auto;">
          Ciencia e tecnica no <em>desenvolvimento de cada formula</em>
        </h1>
        <p class="cl-pg-lead" style="text-align:center;max-width:66rem;margin-left:auto;margin-right:auto;margin-bottom:4rem;">
          Cada produto Clenear nasce de um processo rigoroso de pesquisa, teste e validacao. Investimos em P&amp;D para entregar formulacoes que se destacam em desempenho, seguranca e sustentabilidade.
        </p>
        <div class="cl-pg-btn-row" style="justify-content:center;">
          <a href="https://api.whatsapp.com/send?phone=552732280140&amp;text=Ol%C3%A1!%20Vim%20pelo%20site%20da%20Clenear%20e%20gostaria%20de%20falar%20com%20o%20Setor%20T%C3%A9cnico."
             class="cl-pg-btn cl-pg-btn--wa" target="_blank" rel="noopener">
            Falar com o Setor Tecnico
          </a>
          <a href="/pages/nossas-linhas" class="cl-pg-btn cl-pg-btn--outline">
            Conheca Nossas Linhas
          </a>
        </div>
      </div>
    </div>
    <div class="cl-pi-hero__scroll-hint" aria-hidden="true"><span></span></div>
  </section>

  {%- comment -%} ===== PILARES ===== {%- endcomment -%}
  <section class="cl-pg-section cl-pg-section--alt cl-pi-section" data-cursor-section>
    <div class="cl-pg-wrap">
      <div class="cl-pg-intro cl-pg-intro--center cl-pg-fade">
        <p class="cl-pg-eyebrow">{{ section.settings.pilares_eyebrow | default: 'Nossos pilares' }}</p>
        <h2 class="cl-pg-h2">{{ section.settings.pilares_title | default: 'Como desenvolvemos cada produto' }}</h2>
        <p class="cl-pg-lead cl-pg-lead--wide">{{ section.settings.pilares_subtitle | default: 'Quatro pilares guiam o nosso processo de pesquisa e desenvolvimento desde a concepcao ate o produto final.' }}</p>
      </div>
      <div class="cl-pg-cards cl-pg-cards--4 cl-pg-fade cl-pg-fade--d1 cl-pi-desktop-cards">
        {%- for block in section.blocks -%}
          {%- if block.type == 'pilar' -%}
            <div class="cl-pg-card cl-pi-card" {{ block.shopify_attributes }}>
              <div class="cl-pg-card__number">{{ block.settings.number | default: '01' }}</div>
              <div class="cl-pi-card__icon-wrap"><span class="cl-pg-card__icon" aria-hidden="true">{{ block.settings.icon }}</span></div>
              <h3 class="cl-pg-card__title">{{ block.settings.title }}</h3>
              <p class="cl-pg-card__text">{{ block.settings.text }}</p>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
      <div class="cl-pi-carousel cl-pg-fade cl-pg-fade--d1">
        <div class="cl-pi-carousel__track" id="cl-pilares-track">
          {%- for block in section.blocks -%}
            {%- if block.type == 'pilar' -%}
              <div class="cl-pg-card cl-pi-card cl-pi-carousel__item" {{ block.shopify_attributes }}>
                <div class="cl-pg-card__number">{{ block.settings.number | default: '01' }}</div>
                <div class="cl-pi-card__icon-wrap"><span class="cl-pg-card__icon" aria-hidden="true">{{ block.settings.icon }}</span></div>
                <h3 class="cl-pg-card__title">{{ block.settings.title }}</h3>
                <p class="cl-pg-card__text">{{ block.settings.text }}</p>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
        <div class="cl-pi-carousel__dots" id="cl-pilares-dots" aria-hidden="true"></div>
      </div>
    </div>
  </section>

  {%- comment -%} ===== STATS ===== {%- endcomment -%}
  <section class="cl-pg-section cl-pg-section--dark cl-pi-stats-section" data-cursor-section>
    <div class="cl-pg-wrap">
      <div class="cl-pi-stats cl-pg-fade">
        <div class="cl-pi-stat"><span class="cl-pi-stat__value">+18</span><span class="cl-pi-stat__label">anos de experiencia</span></div>
        <div class="cl-pi-stat__divider" aria-hidden="true"></div>
        <div class="cl-pi-stat"><span class="cl-pi-stat__value">+50</span><span class="cl-pi-stat__label">formulacoes desenvolvidas</span></div>
        <div class="cl-pi-stat__divider" aria-hidden="true"></div>
        <div class="cl-pi-stat"><span class="cl-pi-stat__value">100%</span><span class="cl-pi-stat__label">desenvolvimento interno</span></div>
        <div class="cl-pi-stat__divider" aria-hidden="true"></div>
        <div class="cl-pi-stat"><span class="cl-pi-stat__value">Lab</span><span class="cl-pi-stat__label">proprio em Serra, ES</span></div>
      </div>
    </div>
  </section>

  {%- comment -%} ===== PROCESSO ===== {%- endcomment -%}
  <section class="cl-pg-section cl-pg-section--alt cl-pi-section" data-cursor-section>
    <div class="cl-pg-wrap">
      <div class="cl-pg-split">
        <div class="cl-pg-fade">
          <p class="cl-pg-eyebrow">{{ section.settings.proc_eyebrow | default: 'Da ideia ao produto' }}</p>
          <h2 class="cl-pg-h2">{{ section.settings.proc_title | default: 'Um processo rigoroso de desenvolvimento' }}</h2>
          <p class="cl-pg-lead">{{ section.settings.proc_text | default: 'Nenhum produto chega ao mercado sem passar por fases estruturadas de pesquisa, formulacao, testes de campo e validacao de seguranca.' }}</p>
          <ul class="cl-pg-split__list cl-pi-steps">
            {%- assign step_num = 1 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'processo_item' -%}
                <li class="cl-pi-step" {{ block.shopify_attributes }}>
                  <span class="cl-pi-step__num">0{{ step_num }}</span>
                  <span class="cl-pi-step__text">{{ block.settings.text }}</span>
                </li>
                {%- assign step_num = step_num | plus: 1 -%}
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </div>
        <div class="cl-pg-split__media cl-pg-fade cl-pg-fade--d2">
          {%- if section.settings.proc_image != blank -%}
            {{ section.settings.proc_image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '400, 700, 800', sizes: '(min-width: 1024px) 44vw, 90vw', alt: 'Processo de P&D Clenear' }}
          {%- else -%}
            <div class="cl-pg-placeholder cl-pi-placeholder-glow">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2v-4M9 21H5a2 2 0 0 1-2-2v-4m0 0h18"/></svg>
              <span>Foto laboratorio / processo (16:9)</span>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ===== PARCERIA TECNICA ===== {%- endcomment -%}
  <section class="cl-pg-section cl-pg-section--dark cl-pi-section" data-cursor-section>
    <div class="cl-pg-wrap">
      <div class="cl-pg-split cl-pg-split--flip">
        <div class="cl-pg-split__media cl-pg-fade">
          {%- if section.settings.parceria_image != blank -%}
            {{ section.settings.parceria_image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '400, 700, 800', sizes: '(min-width: 1024px) 44vw, 90vw', alt: 'Parceria tecnica Clenear' }}
          {%- else -%}
            <div class="cl-pg-placeholder cl-pi-placeholder-glow">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              <span>Foto reuniao / parceria (16:9)</span>
            </div>
          {%- endif -%}
        </div>
        <div class="cl-pg-fade cl-pg-fade--d1">
          <p class="cl-pg-eyebrow">{{ section.settings.parceria_eyebrow | default: 'Desenvolvimento colaborativo' }}</p>
          <h2 class="cl-pg-h2">{{ section.settings.parceria_title | default: 'Formulamos sob medida para o seu negocio' }}</h2>
          <p class="cl-pg-lead">{{ section.settings.parceria_text | default: 'Seja para criar uma nova linha, adaptar uma formulacao ou desenvolver um produto exclusivo, nosso time tecnico trabalha ao seu lado em cada etapa.' }}</p>
          <ul class="cl-pg-split__list">
            {%- for block in section.blocks -%}
              {%- if block.type == 'parceria_item' -%}
                <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
          <div class="cl-pg-btn-row">
            <a href="https://api.whatsapp.com/send?phone=552732280140&amp;text=Ol%C3%A1!%20Vim%20pelo%20site%20da%20Clenear%20e%20gostaria%20de%20falar%20sobre%20desenvolvimento%20de%20formula."
               class="cl-pg-btn cl-pg-btn--wa" target="_blank" rel="noopener">
              Falar com o Setor Tecnico
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ===== MID CTA ===== {%- endcomment -%}
  <section class="cl-pg-section cl-pg-section--alt cl-pi-section" data-cursor-section>
    <div class="cl-pg-wrap">
      <div class="cl-pg-mid-cta cl-pg-fade">
        <p class="cl-pg-eyebrow" style="text-align:center;">{{ section.settings.mid_cta_eyebrow | default: 'Vamos conversar?' }}</p>
        <h3>{{ section.settings.mid_cta_heading | default: 'Tem uma necessidade tecnica especifica?' }}</h3>
        <p>{{ section.settings.mid_cta_text | default: 'Nossa equipe de P&amp;D esta pronta para desenvolver a formulacao ideal para o seu segmento.' }}</p>
        <div class="cl-pg-btn-row">
          <a href="https://api.whatsapp.com/send?phone=552732280140&amp;text=Ol%C3%A1!%20Vim%20pelo%20site%20da%20Clenear%20e%20gostaria%20de%20falar%20com%20o%20Setor%20T%C3%A9cnico."
             class="cl-pg-btn cl-pg-btn--wa" target="_blank" rel="noopener">
            Falar com o Setor Tecnico
          </a>
          <a href="/pages/nossas-linhas" class="cl-pg-btn cl-pg-btn--outline">
            Conheca Nossas Linhas
          </a>
        </div>
      </div>
    </div>
  </section>

</div>

<script src="{{ 'clenear-pi.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Clenear: Pesquisa e Inovacao",
  "settings": [
    { "type": "header", "content": "Secao: Pilares" },
    { "type": "text", "id": "pilares_eyebrow", "label": "Eyebrow", "default": "Nossos pilares" },
    { "type": "text", "id": "pilares_title", "label": "Titulo", "default": "Como desenvolvemos cada produto" },
    { "type": "textarea", "id": "pilares_subtitle", "label": "Subtitulo" },
    { "type": "header", "content": "Secao: Processo" },
    { "type": "text", "id": "proc_eyebrow", "label": "Eyebrow", "default": "Da ideia ao produto" },
    { "type": "text", "id": "proc_title", "label": "Titulo", "default": "Um processo rigoroso de desenvolvimento" },
    { "type": "textarea", "id": "proc_text", "label": "Texto" },
    { "type": "image_picker", "id": "proc_image", "label": "Imagem processo (16:9)" },
    { "type": "header", "content": "Secao: Parceria tecnica" },
    { "type": "text", "id": "parceria_eyebrow", "label": "Eyebrow", "default": "Desenvolvimento colaborativo" },
    { "type": "text", "id": "parceria_title", "label": "Titulo", "default": "Formulamos sob medida para o seu negocio" },
    { "type": "textarea", "id": "parceria_text", "label": "Texto" },
    { "type": "image_picker", "id": "parceria_image", "label": "Imagem parceria (16:9)" },
    { "type": "header", "content": "Mid CTA" },
    { "type": "text", "id": "mid_cta_eyebrow", "label": "Eyebrow", "default": "Vamos conversar?" },
    { "type": "text", "id": "mid_cta_heading", "label": "Titulo", "default": "Tem uma necessidade tecnica especifica?" },
    { "type": "textarea", "id": "mid_cta_text", "label": "Texto" }
  ],
  "blocks": [
    {
      "type": "pilar",
      "name": "Pilar",
      "settings": [
        { "type": "text", "id": "number", "label": "Numero", "default": "01" },
        { "type": "text", "id": "icon", "label": "Emoji", "default": "🔬" },
        { "type": "text", "id": "title", "label": "Titulo" },
        { "type": "textarea", "id": "text", "label": "Descricao" }
      ]
    },
    {
      "type": "processo_item",
      "name": "Item do processo",
      "settings": [
        { "type": "text", "id": "text", "label": "Texto do item" }
      ]
    },
    {
      "type": "parceria_item",
      "name": "Item de parceria",
      "settings": [
        { "type": "text", "id": "text", "label": "Texto do item" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Clenear: Pesquisa e Inovacao"
    }
  ]
}
{% endschema %}
