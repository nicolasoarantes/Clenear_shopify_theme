      "name": "Missão / Visão / Valor",
      "settings": [
        { "type": "text", "id": "icon", "label": "Emoji", "default": "🎯" },
        { "type": "text", "id": "label", "label": "Label (Missão, Visão ou Valores)", "default": "Missão" },
        { "type": "text", "id": "title", "label": "Título" },
