{{ 'clenear-pages.css' | asset_url | stylesheet_tag }}

<div class="cl-pg-page" id="sobre">

  {%- comment -%} CURSOR GLOW {%- endcomment -%}
  <div class="cl-cursor-glow" id="cl-sobre-glow" aria-hidden="true"></div>

  {%- comment -%} ===== HERO ===== {%- endcomment -%}
  <section class="cl-pg-hero" style="position:relative;">
    <div class="cl-pg-wrap">
      <div class="cl-pg-hero__grid">
        <div class="cl-pg-hero__content cl-pg-fade">
          <p class="cl-pg-eyebrow">{{ section.settings.hero_eyebrow | default: 'Nossa história' }}</p>
          <h1 class="cl-pg-h1">{{ section.settings.hero_title | default: 'Comprometidos com <em>qualidade e resultado</em>' }}</h1>
          <p class="cl-pg-lead">{{ section.settings.hero_subtitle | default: 'Desde 2006, a Clenear desenvolve soluções de limpeza e saneantes para empresas, revendedores e parceiros em todo o Espírito Santo e Brasil.' }}</p>
          <div class="cl-pg-btn-row">
            <a href="{{ section.settings.cta_wa_url | default: 'https://api.whatsapp.com/send?phone=552732280140&text=Ol%C3%A1!%20Vim%20pelo%20site%20da%20Clenear%20e%20gostaria%20de%20saber%20mais%20sobre%20a%20empresa.' }}" class="cl-pg-btn cl-pg-btn--wa" target="_blank" rel="noopener">
              {{ section.settings.cta_wa_label | default: 'Falar no WhatsApp' }}
            </a>
            <a href="{{ section.settings.cta2_url | default: '/pages/contato' }}" class="cl-pg-btn cl-pg-btn--outline">
              {{ section.settings.cta2_label | default: 'Formulário de contato' }}
            </a>
          </div>
        </div>
        <div class="cl-pg-hero__media cl-pg-fade cl-pg-fade--d2">
          {%- if section.settings.hero_image != blank -%}
            {{ section.settings.hero_image | image_url: width: 800 | image_tag: loading: 'eager', widths: '400, 600, 800', sizes: '(min-width: 1024px) 44vw, 90vw', alt: section.settings.hero_image_alt | default: 'Equipe e instalações Clenear' }}
          {%- else -%}
            <div class="cl-pg-placeholder">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
              <span>Foto da equipe ou ambiente industrial<br>(aspect 4:3)</span>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ===== STATS ===== {%- endcomment -%}
  <div class="cl-pg-stats">
    <div class="cl-pg-wrap">
      <div class="cl-pg-stats__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'stat' -%}
            <div class="cl-pg-stat cl-pg-fade" {{ block.shopify_attributes }}>
              <strong>{{ block.settings.value }}</strong>
              <span>{{ block.settings.label }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  {%- comment -%} ===== HISTÓRIA — TIMELINE ===== {%- endcomment -%}
  <section class="cl-pg-section cl-pg-section--alt">
    <div class="cl-pg-wrap">
      <div class="cl-pg-intro cl-pg-fade">
        <p class="cl-pg-eyebrow">{{ section.settings.history_eyebrow | default: 'Nossa trajetória' }}</p>
        <h2 class="cl-pg-h2">{{ section.settings.history_title | default: 'Uma história construída com <em>trabalho e técnica</em>' }}</h2>
        <p class="cl-pg-lead">{{ section.settings.history_subtitle | default: 'Cada etapa da Clenear foi marcada por aprendizado, investimento em pesquisa e compromisso com os clientes.' }}</p>
      </div>
      <div class="cl-pg-timeline">
        {%- for block in section.blocks -%}
          {%- if block.type == 'timeline_item' -%}
            <div class="cl-pg-tl-item cl-pg-fade" {{ block.shopify_attributes }}>
              <p class="cl-pg-tl-year">{{ block.settings.year }}</p>
              <h3>{{ block.settings.title }}</h3>
              <p>{{ block.settings.text }}</p>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>

  {%- comment -%} ===== MISSÃO / VISÃO / VALORES ===== {%- endcomment -%}
  <section class="cl-pg-section cl-pg-section--dark">
    <div class="cl-pg-wrap">
      <div class="cl-pg-intro cl-pg-intro--center cl-pg-fade">
        <p class="cl-pg-eyebrow">{{ section.settings.mvv_eyebrow | default: 'Propósito e valores' }}</p>
        <h2 class="cl-pg-h2">{{ section.settings.mvv_title | default: 'O que nos move' }}</h2>
      </div>
      <div class="cl-pg-mvv">
        {%- for block in section.blocks -%}
          {%- if block.type == 'mvv_card' -%}
            <div class="cl-pg-mvv-card cl-pg-fade cl-pg-fade--d{{ forloop.index }}" {{ block.shopify_attributes }}>
              <div class="cl-pg-mvv-card__icon">{{ block.settings.icon }}</div>
              <p class="cl-pg-mvv-card__label">{{ block.settings.label }}</p>
              <h3>{{ block.settings.title }}</h3>
              <p>{{ block.settings.text }}</p>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
      <div class="cl-pg-scroll-dots" aria-hidden="true">
        <span></span><span></span><span></span>
      </div>
    </div>
  </section>

  {%- comment -%} ===== DIFERENCIAIS ===== {%- endcomment -%}
  <section class="cl-pg-section cl-pg-section--alt">
    <div class="cl-pg-wrap">
      <div class="cl-pg-intro cl-pg-fade">
        <p class="cl-pg-eyebrow">{{ section.settings.diff_eyebrow | default: 'Por que a Clenear' }}</p>
        <h2 class="cl-pg-h2">{{ section.settings.diff_title | default: 'Nossos <em>diferenciais</em>' }}</h2>
      </div>
      <div class="cl-pg-diffs">
        {%- for block in section.blocks -%}
          {%- if block.type == 'diferencial' -%}
            <div class="cl-pg-diff cl-pg-fade cl-pg-fade--d{{ forloop.index }}" {{ block.shopify_attributes }}>
              <div class="cl-pg-diff__icon">{{ block.settings.icon }}</div>
              <h3>{{ block.settings.title }}</h3>
              <p>{{ block.settings.text }}</p>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- comment -%} MID CTA {%- endcomment -%}
      <div class="cl-pg-mid-cta cl-pg-fade">
        <h3>{{ section.settings.mid_cta_heading | default: 'Pronto para conhecer nossas soluções?' }}</h3>
        <p>{{ section.settings.mid_cta_text | default: 'Fale com nosso time e descubra como a Clenear pode ser o parceiro ideal para o seu negócio.' }}</p>
        <div class="cl-pg-btn-row">
          <a href="{{ section.settings.cta_wa_url | default: 'https://api.whatsapp.com/send?phone=552732280140&text=Ol%C3%A1!%20Vim%20pelo%20site%20da%20Clenear%20e%20gostaria%20de%20conhecer%20as%20solu%C3%A7%C3%B5es%20da%20empresa.' }}" class="cl-pg-btn cl-pg-btn--wa" target="_blank" rel="noopener">
            {{ section.settings.cta_wa_label | default: 'Falar no WhatsApp' }}
          </a>
          <a href="{{ section.settings.cta2_url | default: '/pages/contato' }}" class="cl-pg-btn cl-pg-btn--outline">
            {{ section.settings.cta2_label | default: 'Formulário de contato' }}
          </a>
        </div>
      </div>
    </div>
  </section>

</div>

<script>
(function () {
  /* ── Scroll fade-in ── */
  var fades = document.querySelectorAll('#sobre .cl-pg-fade');
  if ('IntersectionObserver' in window) {
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
      });
    }, { threshold: 0.12 });
    fades.forEach(function (el) { io.observe(el); });
  } else {
    fades.forEach(function (el) { el.classList.add('is-visible'); });
  }

  /* ── Cursor glow ── */
  var glow = document.getElementById('cl-sobre-glow');
  if (glow && window.matchMedia('(pointer: fine)').matches) {
    var tx = window.innerWidth / 2, ty = window.innerHeight / 2;
    var cx = tx, cy = ty;
    function lerp(a, b, t) { return a + (b - a) * t; }
    document.addEventListener('mousemove', function (e) { tx = e.clientX; ty = e.clientY; });
    (function tick() {
      cx = lerp(cx, tx, 0.08);
      cy = lerp(cy, ty, 0.08);
      glow.style.transform = 'translate(calc(' + cx + 'px - 50%), calc(' + cy + 'px - 50%))';
      requestAnimationFrame(tick);
    })();
  }
})();
</script>

{% schema %}
{
