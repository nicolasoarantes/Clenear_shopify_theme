<section class="cl-section cl-solutions" id="solucoes">
  <div class="cl-wrap">
    <div class="cl-solutions__intro">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <p class="cl-label">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        <h2 class="cl-h2">{{ section.settings.heading }}</h2>
        {%- if section.settings.subtext != blank -%}
          <p class="cl-lead">{{ section.settings.subtext }}</p>
        {%- endif -%}
      </div>
    </div>

    <div class="cl-sol-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'solution' -%}
          {%- assign solution_link = block.settings.link | default: section.settings.default_link | default: 'https://api.whatsapp.com/send?phone=552732280140&text=Ol%C3%A1!%20Vim%20pelo%20site%20da%20Clenear%20e%20gostaria%20de%20ajuda%20para%20escolher%20a%20linha%20ideal%20para%20minha%20necessidade.' -%}
          <a
            href="{{ solution_link }}"
            class="cl-sol-card cl-fade-in"
            {% if solution_link contains 'http' %}
              target="_blank" rel="noopener"
            {% endif %}
            {{ block.shopify_attributes }}
          >
            <div class="cl-sol-card__icon" aria-hidden="true">
              {%- case block.settings.icon_key -%}
              {%- when 'domissanitaria' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M10 3h3v3h-3z"/><path d="M13 3.5l4-1M13 5.5l4 1"/><path d="M8 6h6a3 3 0 0 1 3 3v9a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2v-7a4 4 0 0 1 1-3z"/><path d="M10 13h4"/></svg>
              {%- when 'lavanderia' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="3" width="14" height="18" rx="2"/><circle cx="12" cy="13" r="4.5"/><circle cx="8" cy="6" r=".5" fill="currentColor"/><circle cx="11" cy="6" r=".5" fill="currentColor"/></svg>
              {%- when 'automotiva' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M5 11l2-5h10l2 5"/><rect x="3" y="11" width="18" height="6" rx="2"/><circle cx="7.5" cy="17.5" r="1.6"/><circle cx="16.5" cy="17.5" r="1.6"/></svg>
              {%- when 'industrial' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21V11l6 3.5V11l6 3.5V8l6 3v9z"/><path d="M3 21h18"/></svg>
              {%- when 'construcao-civil' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="13" width="7" height="8"/><rect x="14" y="13" width="7" height="8"/><rect x="8" y="3" width="8" height="8"/></svg>
              {%- when 'insumos' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6"/><path d="M10 3v6l-5 8.5A2 2 0 0 0 7 21h10a2 2 0 0 0 1.8-3.5L14 9V3"/><path d="M8.5 15h7"/></svg>
              {%- else -%}{{ block.settings.emoji }}
              {%- endcase -%}
            </div>
            <h3 class="cl-sol-card__title">{{ block.settings.title | escape }}</h3>
            <p class="cl-sol-card__text">{{ block.settings.text | escape }}</p>
            <span class="cl-sol-card__link">Saiba mais -></span>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #solucoes .cl-sol-card__icon{width:7rem;height:7rem;background:var(--cl-green-soft);color:var(--cl-green-dark);border-radius:1.4rem}
  #solucoes .cl-sol-card__icon svg{width:3.6rem;height:3.6rem}
  @media (max-width:749px){#solucoes .cl-sol-card__icon{width:6rem;height:6rem}#solucoes .cl-sol-card__icon svg{width:3rem;height:3rem}}
</style>

{% schema %}
{
  "name": "Clenear: Grid Soluções",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Soluções completas"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Linhas para cada necessidade"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtexto",
      "default": "Produtos para diferentes segmentos, com qualidade, performance e suporte técnico."
    },
    {
      "type": "url",
      "id": "default_link",
      "label": "Link padrão dos cards"
    }
  ],
  "blocks": [
    {
      "type": "solution",
      "name": "Solução",
      "settings": [
        {
          "type": "text",
          "id": "emoji",
          "label": "Emoji (fallback)",
          "default": "🧺"
        },
        {
          "type": "text",
          "id": "icon_key",
          "label": "Ícone da marca (chave)",
          "info": "Use: domissanitaria, lavanderia, automotiva, industrial, construcao-civil ou insumos"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Descrição"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Clenear Soluções Grid",
      "blocks": [
        {
          "type": "solution",
          "settings": {
            "emoji": "🧽",
            "title": "Domissanitária",
            "text": "Limpeza, higienização, desinfecção e perfumação de ambientes."
          }
        },
        {
          "type": "solution",
          "settings": {
            "emoji": "🧺",
            "title": "Lavanderia",
            "text": "Amaciantes, detergentes e soluções para higienização têxtil."
          }
        },
        {
          "type": "solution",
          "settings": {
            "emoji": "🚗",
            "title": "Automotiva",
            "text": "Linha completa: Brilha+, Limpa+, Descola+, Revita+."
          }
        },
        {
          "type": "solution",
          "settings": {
            "emoji": "🏭",
            "title": "Industrial",
            "text": "Limpeza pesada, manutenção e processos produtivos."
          }
        },
        {
          "type": "solution",
          "settings": {
            "emoji": "🧱",
            "title": "Construção Civil",
            "text": "Aditivos e soluções técnicas para concreto, formas e superfícies."
          }
        },
        {
          "type": "solution",
          "settings": {
            "emoji": "⚗️",
            "title": "Insumos e Revenda",
            "text": "Insumos, embalagens, acessórios e produtos de revenda."
          }
        }
      ]
    }
  ]
}
{% endschema %}
