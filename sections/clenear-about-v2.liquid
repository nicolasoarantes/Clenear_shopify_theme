<section class="cl-section cl-about" id="sobre"><div class="cl-wrap"><div class="cl-about__grid">
  <div>
    {%- if section.settings.eyebrow != blank -%}<p class="cl-label">{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
    <h2 class="cl-h2">{{ section.settings.heading }}</h2>
    {%- if section.settings.text != blank -%}<p class="cl-lead">{{ section.settings.text }}</p>{%- endif -%}
    {%- if section.settings.purpose != blank -%}<blockquote style="margin:2.8rem 0 0;padding:2rem 2.4rem;border-left:4px solid var(--cl-green);background:var(--cl-green-soft);border-radius:0 var(--cl-radius-sm) var(--cl-radius-sm) 0;"><p style="font-size:1.7rem;line-height:1.6;color:var(--cl-ink-mid);font-style:italic;margin:0;">"{{ section.settings.purpose | escape }}"</p></blockquote>{%- endif -%}
    <div class="cl-about__stats">{%- for block in section.blocks -%}{%- if block.type == 'stat' -%}<div {{ block.shopify_attributes }}><div class="cl-about__stat-num">{{ block.settings.value | escape }}</div><div class="cl-about__stat-label">{{ block.settings.label | escape }}</div></div>{%- endif -%}{%- endfor -%}</div>
    <div class="cl-btn-row" style="margin-top:3.6rem;">{%- if section.settings.cta_label != blank -%}<a href="{{ section.settings.cta_url }}" class="cl-btn cl-btn--primary">{{ section.settings.cta_label | escape }}</a>{%- endif -%}</div>
  </div>
  <div class="cl-about__img-wrap">
    <div class="cl-about__img-main">{%- if section.settings.image != blank -%}{{ section.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '400, 600, 800', sizes: '(min-width: 1024px) 40vw, 90vw', alt: 'Equipe Clenear' }}{%- else -%}<div style="width:100%;height:100%;background:linear-gradient(160deg,#EBF7F0,#D4E8DB);display:flex;align-items:center;justify-content:center;color:var(--cl-muted);font-size:1.5rem;padding:3.2rem;text-align:center;">Adicione uma foto da equipe</div>{%- endif -%}</div>
    <div class="cl-about__img-accent"><strong>{{ section.settings.accent_value | default: '2006' }}</strong><span>{{ section.settings.accent_label | default: 'fundação da Clenear' }}</span></div>
  </div>
</div></div></section>
{% schema %}{"name":"Clenear: Sobre V2","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Quem é a Clenear"},{"type":"text","id":"heading","label":"Título","default":"Indústria capixaba comprometida"},{"type":"textarea","id":"text","label":"Texto","default":"Desde 2006, a Clenear desenvolve saneantes e soluções de limpeza profissional para empresas, revendedores e parceiros."},{"type":"textarea","id":"purpose","label":"Propósito","default":"Oferecer soluções eficazes e produtos de alta qualidade que enriquecem a vida dos nossos clientes."},{"type":"image_picker","id":"image","label":"Imagem"},{"type":"text","id":"accent_value","label":"Destaque número","default":"2006"},{"type":"text","id":"accent_label","label":"Destaque texto","default":"fundação da Clenear"},{"type":"text","id":"cta_label","label":"CTA","default":"Nossa história"},{"type":"url","id":"cta_url","label":"CTA link"}],"blocks":[{"type":"stat","name":"Stat","settings":[{"type":"text","id":"value","label":"Número"},{"type":"text","id":"label","label":"Label"}]}],"presets":[{"name":"Clenear Sobre V2","blocks":[{"type":"stat","settings":{"value":"+18 anos","label":"de experiência"}},{"type":"stat","settings":{"value":"+50","label":"produtos"}},{"type":"stat","settings":{"value":"ES BR","label":"todo o país"}},{"type":"stat","settings":{"value":"B2B","label":"foco empresarial"}}]}]}{% endschema %}