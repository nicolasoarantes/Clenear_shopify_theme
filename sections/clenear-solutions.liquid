<section id="solucoes" class="clenear-institutional-shell clenear-section clenear-section--soft">
  <div class="clenear-container">
    <div class="clenear-centered">
      {%- if section.settings.eyebrow != blank -%}
        <p class="clenear-eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      <h2 class="clenear-heading clenear-heading--section">{{ section.settings.heading }}</h2>
      {%- if section.settings.text != blank -%}
        <p class="clenear-text">{{ section.settings.text }}</p>
      {%- endif -%}
    </div>

    <div class="clenear-card-grid">
      {%- for block in section.blocks -%}
        <article class="clenear-card" {{ block.shopify_attributes }}>
          <span class="clenear-card__mark" aria-hidden="true"></span>
          <h3>{{ block.settings.heading }}</h3>
          <p>{{ block.settings.text }}</p>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Clenear soluções",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto superior",
      "default": "Soluções atendidas"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Titulo",
      "default": "Linhas pensadas para operações profissionais"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Texto",
      "default": "Atendimento para empresas, revendedores e marcas que precisam de regularidade, rendimento e suporte na escolha da solução adequada."
    }
  ],
  "blocks": [
    {
      "type": "solution",
      "name": "Solução",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Titulo",
          "default": "Limpeza profissional"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Texto",
          "default": "Soluções para ambientes comerciais, industriais e operações que exigem alto desempenho."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Clenear soluções",
      "blocks": [
        { "type": "solution" },
        { "type": "solution" },
        { "type": "solution" }
      ]
    }
  ]
}
{% endschema %}
